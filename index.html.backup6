const SUPABASE_URL = 'https://nuebqtzeirpyyxtoptlp.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im51ZWJxdHplaXJweXl4dG9wdGxwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk1NDI0NzgsImV4cCI6MjA5NTExODQ3OH0.Yw_8t-PVCDfFZPzV4F5jZjratLkAIE9X9sRdq2qme9Y';

async function sbFetch(path, options = {}) {
  const res = await fetch(SUPABASE_URL + '/rest/v1/' + path, {
    ...options,
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': 'Bearer ' + SUPABASE_KEY,
      'Content-Type': 'application/json',
      'Prefer': options.prefer || 'return=minimal',
      ...(options.headers || {})
    }
  });
  if (!res.ok) throw new Error(await res.text());
  const text = await res.text();
  return text ? JSON.parse(text) : null;
}

// ── YORUM SİSTEMİ ─────────────────────────────────────────────────────────────
let commentPlaceId = null;
let commentStar = 0;

async function loadComments(placeId) {
  const listEl = document.getElementById('comments-list');
  listEl.innerHTML = '<div class="comment-loading">⏳ ' + (lang==='tr'?'Yorumlar yükleniyor...':'Loading comments...') + '</div>';
  try {
    const data = await sbFetch(
      `comments?place_id=eq.${encodeURIComponent(placeId)}&order=created_at.desc&limit=20`,
      { headers: { 'Prefer': '' } }
    );
    renderComments(data || []);
  } catch(e) {
    listEl.innerHTML = '<div class="comment-empty">⚠️ ' + (lang==='tr'?'Yorumlar yüklenemedi.':'Could not load comments.') + '</div>';
    console.warn('[Comments]', e);
  }
}

function renderComments(comments) {
  const listEl = document.getElementById('comments-list');
  if (!comments.length) {
    listEl.innerHTML = '<div class="comment-empty">💬 ' + (lang==='tr'?'Henüz yorum yok. İlk yorumu sen yaz!':'No comments yet. Be the first!') + '</div>';
    const box = document.getElementById('comment-input-box');
    const section = listEl.parentNode;
    if (box && section) section.appendChild(box);
    return;
  }

  const myUserId = currentUser ? currentUser.id : null;

  listEl.innerHTML = comments.map(c => {
    const stars = c.stars ? '★'.repeat(c.stars) + '☆'.repeat(5 - c.stars) : '';
    const date = new Date(c.created_at).toLocaleDateString(lang==='tr'?'tr-TR':'en-US', {day:'numeric',month:'short',year:'numeric'});
    const isOwn = myUserId && c.user_id === myUserId;

    return `
      <div class="comment-card" id="comment-card-${c.id}">
        <div class="comment-top">
          <div class="comment-user">${c.username}${isOwn ? ' <span style="font-size:10px;color:var(--gold);font-weight:400;">(sen)</span>' : ''}</div>
          <div class="comment-meta">
            ${stars ? `<span class="comment-stars">${stars}</span>` : ''}
            <span class="comment-date">${date}</span>
          </div>
        </div>
        <div class="comment-text" id="comment-text-${c.id}">${c.text}</div>
        ${isOwn ? `
          <div class="comment-actions">
            <button class="comment-action-btn edit" onclick="startEditComment('${c.id}', '${c.text.replace(/'/g, "\'")}')">
              ✏️ ${lang==='tr'?'Düzenle':'Edit'}
            </button>
            <button class="comment-action-btn delete" onclick="deleteComment('${c.id}')">
              🗑 ${lang==='tr'?'Sil':'Delete'}
            </button>
          </div>` : ''}
      </div>`;
  }).join('');

  // Yorum input box'ı listenin sonuna taşı
  const box = document.getElementById('comment-input-box');
  const section = listEl.parentNode;
  if (box && section) section.appendChild(box);
}

function setCommentStar(n) {
  commentStar = n;
  updateCommentStars(n, false);
}

function hoverCommentStar(n) {
  const stars = document.querySelectorAll('#comment-star-pick span');
  stars.forEach((s, i) => {
    s.classList.toggle('lit', i < n);
  });
}

function unhoverCommentStar() {
  updateCommentStars(commentStar, false);
}

function updateCommentStars(n, reset) {
  const stars = document.querySelectorAll('#comment-star-pick span');
  stars.forEach((s, i) => {
    s.classList.toggle('lit', !reset && i < n);
  });
}

async function submitComment() {
  const username = document.getElementById('comment-username').value.trim();
  const text = document.getElementById('comment-text').value.trim();
  const btn = document.getElementById('comment-submit-btn');

  if (!username) { showToast(lang==='tr'?'Görünen ad gerekli!':'Display name required!'); return; }
  if (!text) { showToast(lang==='tr'?'Yorum metni gerekli!':'Comment text required!'); return; }
  if (text.length < 3) { showToast(lang==='tr'?'Yorum çok kısa!':'Comment too short!'); return; }

  btn.classList.add('loading');
  document.getElementById('comment-submit-label').textContent = lang==='tr'?'Gönderiliyor...':'Sending...';

  try {
    await sbFetch('comments', {
      method: 'POST',
      prefer: 'return=minimal',
      body: JSON.stringify({
        place_id: commentPlaceId,
        username: username,
        text: text,
        stars: commentStar || null,
        user_id: currentUser ? currentUser.id : null
      })
    });

    // Formu temizle
    document.getElementById('comment-text').value = '';
    commentStar = 0;
    updateCommentStars(0, true);

    showToast(lang==='tr'?'✓ Yorum eklendi!':'✓ Comment added!');

    // Yorumları yenile
    await loadComments(commentPlaceId);

  } catch(e) {
    showToast(lang==='tr'?'Yorum gönderilemedi. Tekrar dene.':'Could not send comment. Try again.');
    console.warn('[submitComment]', e);
  } finally {
    btn.classList.remove('loading');
    document.getElementById('comment-submit-label').textContent = lang==='tr'?'Yorum Gönder':'Send Comment';
  }
}


// ── YORUM DÜZENLE / SİL ───────────────────────────────────────────────────────
function startEditComment(commentId, currentText) {
  // Mevcut text'i editable yap
  const textEl = document.getElementById(`comment-text-${commentId}`);
  const card = document.getElementById(`comment-card-${commentId}`);
  if (!textEl || !card) return;

  // Düzenleme arayüzü
  textEl.style.display = 'none';
  
  // Eski edit alanı varsa kaldır
  const oldEdit = card.querySelector('.comment-edit-wrapper');
  if (oldEdit) oldEdit.remove();

  const wrapper = document.createElement('div');
  wrapper.className = 'comment-edit-wrapper';
  wrapper.innerHTML = `
    <textarea class="comment-edit-area" id="edit-area-${commentId}" maxlength="300">${currentText}</textarea>
    <div class="comment-edit-actions">
      <button class="comment-edit-cancel" onclick="cancelEditComment('${commentId}')">
        ${lang==='tr'?'İptal':'Cancel'}
      </button>
      <button class="comment-edit-save" onclick="saveEditComment('${commentId}')">
        ${lang==='tr'?'Kaydet':'Save'}
      </button>
    </div>
  `;
  textEl.insertAdjacentElement('afterend', wrapper);

  // Textarea'ya odaklan
  setTimeout(() => {
    const ta = document.getElementById(`edit-area-${commentId}`);
    if (ta) { ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length); }
  }, 50);

  // Düzenle butonunu gizle
  const actions = card.querySelector('.comment-actions');
  if (actions) actions.style.display = 'none';
}

function cancelEditComment(commentId) {
  const textEl = document.getElementById(`comment-text-${commentId}`);
  const card = document.getElementById(`comment-card-${commentId}`);
  if (!textEl || !card) return;

  textEl.style.display = '';
  const wrapper = card.querySelector('.comment-edit-wrapper');
  if (wrapper) wrapper.remove();
  const actions = card.querySelector('.comment-actions');
  if (actions) actions.style.display = '';
}

async function saveEditComment(commentId) {
  const ta = document.getElementById(`edit-area-${commentId}`);
  if (!ta) return;
  const newText = ta.value.trim();

  if (!newText) { showToast(lang==='tr'?'Yorum boş olamaz!':'Comment cannot be empty!'); return; }
  if (newText.length < 3) { showToast(lang==='tr'?'Yorum çok kısa!':'Comment too short!'); return; }

  const saveBtn = ta.parentNode.querySelector('.comment-edit-save');
  if (saveBtn) { saveBtn.textContent = lang==='tr'?'Kaydediliyor...':'Saving...'; saveBtn.disabled = true; }

  try {
    const token = sessionStorage.getItem('sb_access_token');
    const res = await fetch(`${SUPABASE_URL}/rest/v1/comments?id=eq.${commentId}`, {
      method: 'PATCH',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + (token || SUPABASE_KEY),
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({ text: newText })
    });

    if (!res.ok) throw new Error(await res.text());

    showToast(lang==='tr'?'✓ Yorum güncellendi!':'✓ Comment updated!');
    await loadComments(commentPlaceId);

  } catch(e) {
    showToast(lang==='tr'?'Güncelleme başarısız.':'Update failed.');
    console.warn('[saveEditComment]', e);
    if (saveBtn) { saveBtn.textContent = lang==='tr'?'Kaydet':'Save'; saveBtn.disabled = false; }
  }
}

async function deleteComment(commentId) {
  // Onay iste
  const confirmed = confirm(lang==='tr'?'Yorumu silmek istediğinden emin misin?':'Are you sure you want to delete this comment?');
  if (!confirmed) return;

  try {
    const token = sessionStorage.getItem('sb_access_token');
    const res = await fetch(`${SUPABASE_URL}/rest/v1/comments?id=eq.${commentId}`, {
      method: 'DELETE',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + (token || SUPABASE_KEY),
        'Prefer': 'return=minimal'
      }
    });

    if (!res.ok) throw new Error(await res.text());

    // Kartı animasyonla kaldır
    const card = document.getElementById(`comment-card-${commentId}`);
    if (card) {
      card.style.transition = 'opacity 0.2s, transform 0.2s';
      card.style.opacity = '0';
      card.style.transform = 'translateX(-10px)';
      setTimeout(() => {
        card.remove();
        // Liste boşaldıysa boş mesaj göster
        const listEl = document.getElementById('comments-list');
        if (listEl && !listEl.querySelector('.comment-card')) {
          listEl.innerHTML = '<div class="comment-empty">💬 ' + (lang==='tr'?'Henüz yorum yok. İlk yorumu sen yaz!':'No comments yet. Be the first!') + '</div>';
        }
      }, 200);
    }

    showToast(lang==='tr'?'🗑 Yorum silindi.':'🗑 Comment deleted.');

  } catch(e) {
    showToast(lang==='tr'?'Silme başarısız.':'Delete failed.');
    console.warn('[deleteComment]', e);
  }
}

function scrollToCommentInput() {
  const box = document.getElementById('comment-input-box');
  if (box) box.scrollIntoView({behavior:'smooth', block:'center'});
  const ta = document.getElementById('comment-text');
  if (ta) setTimeout(() => ta.focus(), 400);
}


// ── BİLDİRİM İZNİ ────────────────────────────────────────────────────────────
// Kullanıcı home ekranına gelince izin sor (tek seferlik, nazikçe)
let notifPermissionAsked = false;

function askNotificationPermission() {
  if (notifPermissionAsked) return;
  if (!('Notification' in window)) return; // Tarayıcı desteklemiyor
  if (Notification.permission === 'granted') {
    notifPermissionAsked = true;
    updateNotifStatus('granted');
    return;
  }
  if (Notification.permission === 'denied') {
    notifPermissionAsked = true;
    return;
  }

  // İzin daha istenmemiş — 2 sn bekleyip sor
  notifPermissionAsked = true;
  setTimeout(() => showNotifPrompt(), 2000);
}

function showNotifPrompt() {
  // Mevcut varsa kaldır
  const old = document.getElementById('notif-prompt');
  if (old) old.remove();

  const prompt = document.createElement('div');
  prompt.id = 'notif-prompt';
  prompt.style.cssText = `
    position:absolute; bottom:80px; left:16px; right:16px;
    background:var(--navy); border-radius:16px;
    padding:16px; z-index:90;
    box-shadow:0 8px 32px rgba(0,0,0,0.3);
    display:flex; flex-direction:column; gap:10px;
    animation: slideUp 0.3s ease;
  `;
  prompt.innerHTML = `
    <style>
      @keyframes slideUp {
        from { transform:translateY(20px); opacity:0; }
        to   { transform:translateY(0);    opacity:1; }
      }
    </style>
    <div style="display:flex;align-items:flex-start;gap:10px;">
      <span style="font-size:22px;flex-shrink:0;">🔔</span>
      <div>
        <div style="font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:#fff;margin-bottom:3px;" id="notif-prompt-title">
          ${lang==='tr' ? 'Bildirimler' : 'Notifications'}
        </div>
        <div style="font-size:12px;color:rgba(255,255,255,0.65);line-height:1.5;" id="notif-prompt-desc">
          ${lang==='tr'
            ? 'Gittiğin şehre yeni yer eklenince haberdar ol.'
            : 'Get notified when new places are added to your city.'}
        </div>
      </div>
    </div>
    <div style="display:flex;gap:8px;">
      <button onclick="grantNotifPermission()" style="
        flex:1; padding:10px; border-radius:10px;
        background:var(--gold); color:var(--navy);
        font-family:'Syne',sans-serif; font-size:13px; font-weight:700;
        border:none; cursor:pointer;">
        ${lang==='tr' ? '✓ İzin Ver' : '✓ Allow'}
      </button>
      <button onclick="dismissNotifPrompt()" style="
        flex:1; padding:10px; border-radius:10px;
        background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.7);
        font-size:13px; font-weight:500;
        border:1px solid rgba(255,255,255,0.15); cursor:pointer;">
        ${lang==='tr' ? 'Şimdi Değil' : 'Not Now'}
      </button>
    </div>
  `;

  document.getElementById('app').appendChild(prompt);

  // 8 saniye sonra otomatik kapat
  setTimeout(() => dismissNotifPrompt(), 8000);
}

async function grantNotifPermission() {
  dismissNotifPrompt();
  try {
    const result = await Notification.requestPermission();
    updateNotifStatus(result);
    if (result === 'granted') {
      showToast(lang==='tr' ? '🔔 Bildirimler açık!' : '🔔 Notifications enabled!');
      // SW'a bildir
      if (navigator.serviceWorker.controller) {
        navigator.serviceWorker.controller.postMessage({ type: 'NOTIF_GRANTED' });
      }
      // Push subscription kaydet
      subscribePush();
    } else {
      showToast(lang==='tr' ? 'Bildirimler kapalı.' : 'Notifications disabled.');
    }
  } catch(e) {
    console.warn('[Notif]', e);
  }
}

function dismissNotifPrompt() {
  const el = document.getElementById('notif-prompt');
  if (el) {
    el.style.animation = 'none';
    el.style.opacity = '0';
    el.style.transform = 'translateY(10px)';
    el.style.transition = 'all 0.2s ease';
    setTimeout(() => el.remove(), 200);
  }
}

function updateNotifStatus(status) {
  // Ayarlar ekranına bildirim durumu yansıt
  const el = document.getElementById('notif-status-text');
  if (!el) return;
  const labels = {
    granted: { tr:'🔔 Açık', en:'🔔 On', de:'🔔 Ein', fr:'🔔 Activé', es:'🔔 Activado', ar:'🔔 مفعّل', ja:'🔔 オン', ko:'🔔 켜짐', zh:'🔔 开启' },
    denied:  { tr:'🔕 Kapalı', en:'🔕 Off', de:'🔕 Aus', fr:'🔕 Désactivé', es:'🔕 Desactivado', ar:'🔕 معطّل', ja:'🔕 オフ', ko:'🔕 꺼짐', zh:'🔕 关闭' },
    default: { tr:'⏳ İzin bekleniyor', en:'⏳ Pending', de:'⏳ Ausstehend', fr:'⏳ En attente', es:'⏳ Pendiente', ar:'⏳ في الانتظار', ja:'⏳ 保留中', ko:'⏳ 대기 중', zh:'⏳ 待定' },
  };
  const lbl = labels[status] || labels['default'];
  el.textContent = lbl[lang] || lbl['en'];
  el.style.color = status === 'granted' ? '#10b981' : status === 'denied' ? '#ef4444' : '#f59e0b';
}

function checkNotifStatus() {
  if (!('Notification' in window)) return;
  updateNotifStatus(Notification.permission);
  updateCurrentUsernameDisplay();
  // Input placeholder'ını mevcut kullanıcı adıyla doldur
  const input = document.getElementById('settings-username-input');
  if (input && currentProfile) input.placeholder = currentProfile.username;
}


// ── FOTOĞRAF SİSTEMİ ──────────────────────────────────────────────────────────
let selectedPhotos = []; // { file, previewUrl }
const MAX_PHOTOS = 5;
const MAX_SIZE_MB = 5;

function handlePhotoSelect(input) {
  const files = Array.from(input.files);
  const remaining = MAX_PHOTOS - selectedPhotos.length;
  const toAdd = files.slice(0, remaining);

  toAdd.forEach(file => {
    if (file.size > MAX_SIZE_MB * 1024 * 1024) {
      showToast(lang==='tr' ? `${file.name} çok büyük (max 5 MB)` : `${file.name} too large (max 5 MB)`);
      return;
    }
    if (!file.type.startsWith('image/')) {
      showToast(lang==='tr' ? 'Sadece görsel dosyaları' : 'Images only');
      return;
    }
    const reader = new FileReader();
    reader.onload = (e) => {
      selectedPhotos.push({ file, previewUrl: e.target.result });
      renderPhotoPreviews();
    };
    reader.readAsDataURL(file);
  });

  if (files.length > remaining) {
    showToast(lang==='tr' ? `En fazla ${MAX_PHOTOS} fotoğraf eklenebilir` : `Max ${MAX_PHOTOS} photos allowed`);
  }
  input.value = '';
}

function renderPhotoPreviews() {
  const grid = document.getElementById('photo-preview-grid');
  const area = document.getElementById('photo-upload-area');
  if (!grid) return;

  grid.innerHTML = selectedPhotos.map((p, i) => `
    <div class="photo-preview-item">
      <img src="${p.previewUrl}" alt="photo ${i+1}">
      <button class="photo-preview-remove" onclick="removePhoto(${i})">✕</button>
    </div>
  `).join('');

  // 5'e ulaşınca upload alanını gizle
  if (selectedPhotos.length >= MAX_PHOTOS) {
    area.style.display = 'none';
  } else {
    area.style.display = '';
    document.getElementById('photo-opt').textContent =
      lang==='tr'
        ? `${MAX_PHOTOS - selectedPhotos.length} fotoğraf daha ekleyebilirsin`
        : `${MAX_PHOTOS - selectedPhotos.length} more photos allowed`;
  }
}

function removePhoto(index) {
  selectedPhotos.splice(index, 1);
  renderPhotoPreviews();
}

async function uploadPhotos(placeId) {
  if (selectedPhotos.length === 0) return [];
  const progress = document.getElementById('photo-progress');
  const fill = document.getElementById('photo-progress-fill');
  if (progress) progress.style.display = 'block';

  const urls = [];
  for (let i = 0; i < selectedPhotos.length; i++) {
    const { file } = selectedPhotos[i];
    const ext = file.name.split('.').pop() || 'jpg';
    const path = `${placeId}/${Date.now()}_${i}.${ext}`;

    try {
      // Supabase Storage upload
      const res = await fetch(
        `${SUPABASE_URL}/storage/v1/object/place-photos/${path}`,
        {
          method: 'POST',
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': 'Bearer ' + SUPABASE_KEY,
            'Content-Type': file.type,
            'x-upsert': 'true'
          },
          body: file
        }
      );
      if (!res.ok) throw new Error(await res.text());

      const publicUrl = `${SUPABASE_URL}/storage/v1/object/public/place-photos/${path}`;
      urls.push(publicUrl);

      // photos tablosuna kaydet
      await sbFetch('photos', {
        method: 'POST',
        body: JSON.stringify({ place_id: placeId, url: publicUrl })
      });

    } catch(e) {
      console.warn('[Photo upload]', e);
      showToast(lang==='tr' ? `Fotoğraf ${i+1} yüklenemedi` : `Photo ${i+1} failed`);
    }

    if (fill) fill.style.width = `${((i+1)/selectedPhotos.length)*100}%`;
  }

  if (progress) setTimeout(() => { progress.style.display = 'none'; if(fill) fill.style.width='0%'; }, 800);
  return urls;
}

async function loadPlacePhotos(placeId) {
  try {
    const data = await sbFetch(
      `photos?place_id=eq.${encodeURIComponent(placeId)}&order=created_at.asc&limit=10`,
      { headers: { 'Prefer': '' } }
    );
    renderDetailGallery(data || []);
  } catch(e) {
    console.warn('[Photos]', e);
  }
}

function renderDetailGallery(photos) {
  const gallery = document.getElementById('detail-gallery');
  if (!gallery) return;
  if (!photos.length) { gallery.style.display = 'none'; return; }

  gallery.style.display = 'flex';
  gallery.innerHTML = photos.map((p, i) => `
    <div class="detail-gallery-item" onclick="openLightbox(${i}, ${JSON.stringify(photos.map(x=>x.url)).replace(/"/g,'&quot;')})">
      <img src="${p.url}" alt="photo ${i+1}" loading="lazy">
    </div>
  `).join('');
}

function openLightbox(index, urls) {
  const old = document.getElementById('lightbox');
  if (old) old.remove();

  let cur = index;
  const lb = document.createElement('div');
  lb.id = 'lightbox';
  lb.className = 'lightbox';
  lb.onclick = (e) => { if (e.target === lb) lb.remove(); };

  function render() {
    lb.innerHTML = `
      <button class="lightbox-close" onclick="document.getElementById('lightbox').remove()">✕</button>
      <img src="${urls[cur]}" alt="photo">
      <div class="lightbox-counter">${cur+1} / ${urls.length}</div>
      ${urls.length > 1 ? `
        <div style="display:flex;gap:16px;margin-top:12px;">
          <button onclick="event.stopPropagation();lbPrev()" style="background:rgba(255,255,255,0.15);border:none;color:#fff;padding:8px 20px;border-radius:8px;cursor:pointer;font-size:18px;">‹</button>
          <button onclick="event.stopPropagation();lbNext()" style="background:rgba(255,255,255,0.15);border:none;color:#fff;padding:8px 20px;border-radius:8px;cursor:pointer;font-size:18px;">›</button>
        </div>` : ''}
    `;
  }

  window.lbPrev = () => { cur = (cur - 1 + urls.length) % urls.length; render(); };
  window.lbNext = () => { cur = (cur + 1) % urls.length; render(); };

  render();
  document.getElementById('app').appendChild(lb);
}


// ── AUTH SİSTEMİ ──────────────────────────────────────────────────────────────
let currentUser = null;
let currentProfile = null;

// Supabase Auth API yardımcıları
async function authFetch(path, options = {}) {
  const res = await fetch(SUPABASE_URL + '/auth/v1/' + path, {
    ...options,
    headers: {
      'apikey': SUPABASE_KEY,
      'Content-Type': 'application/json',
      ...(options.headers || {})
    }
  });
  const data = await res.json();
  if (!res.ok) throw new Error(data.error_description || data.msg || JSON.stringify(data));
  return data;
}

// Davet kodu doğrulama
async function verifyInviteCode() {
  const inputEl = document.getElementById('invite-code-input');
  const inputCode = inputEl ? inputEl.value.trim().toUpperCase() : '';
  
  if (!inputCode) {
    showToast(lang==='tr' ? 'Davet kodu gir!' : 'Enter invite code!');
    return;
  }
  
  const btn = document.getElementById('btn-continue');
  btn.textContent = lang==='tr'?'Kontrol ediliyor...':'Checking...';
  btn.disabled = true;

  try {
    const data = await sbFetch(
      `invite_codes?code=eq.${encodeURIComponent(inputCode)}&used_by=is.null&select=code`,
      { headers: { 'Prefer': '' } }
    );
    // Master kod — sınırsız kullanım
    if (inputCode.toUpperCase() === 'CRW-MASTER') {
      sessionStorage.setItem('pendingInviteCode', inputCode);
      sessionStorage.setItem('isMasterInvite', 'true');
      goTo('screen-profile');
      return;
    }
    if (!data || data.length === 0) {
      showToast(lang==='tr'?'Geçersiz veya kullanılmış kod!':'Invalid or used code!');
      return;
    }
    // Kodu sessionStorage'a kaydet
    sessionStorage.setItem('pendingInviteCode', inputCode);
    goTo('screen-profile');
  } catch(e) {
    showToast(lang==='tr'?'Bağlantı hatası, tekrar dene.':'Connection error, try again.');
    console.warn('[verifyInviteCode]', e);
  } finally {
    btn.textContent = lang==='tr'?'Devam Et →':'Continue →';
    btn.disabled = false;
  }
}

// Kayıt ol
async function createAccount() {
  const username = document.getElementById('input-displayname').value.trim();
  const email    = document.getElementById('input-email').value.trim();
  const password = document.getElementById('input-password').value;
  const inviteCode = sessionStorage.getItem('pendingInviteCode') || 'CRW-X7K';

  if (!username) { showToast(lang==='tr'?'Görünen ad gerekli!':'Display name required!'); return; }
  if (!email)    { showToast(lang==='tr'?'E-posta gerekli!':'Email required!'); return; }
  if (password.length < 6) { showToast(lang==='tr'?'Şifre en az 6 karakter!':'Password must be 6+ chars!'); return; }

  const btn = document.getElementById('btn-create-account');
  btn.textContent = lang==='tr'?'Hesap oluşturuluyor...':'Creating account...';
  btn.disabled = true;

  try {
    // 1. Supabase Auth'da kayıt
    const authData = await authFetch('signup', {
      method: 'POST',
      body: JSON.stringify({ email, password })
    });

    const userId = authData.user?.id;
    const accessToken = authData.access_token;
    if (!userId) throw new Error('User ID alınamadı');

    // 2. Profil oluştur (kendi kodu — tek ana kod)
    const newInviteCode = 'CRW-' + Math.random().toString(36).substring(2,5).toUpperCase();
    await fetch(SUPABASE_URL + '/rest/v1/profiles', {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + accessToken,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({
        id: userId,
        username,
        invite_code: newInviteCode,
        invited_by: inviteCode
      })
    });

    // 3. Kullanıcıya 3 adet davet kodu üret
    const inviteCodes = [];
    for (let i = 0; i < 3; i++) {
      const code = 'CRW-' + Math.random().toString(36).substring(2,5).toUpperCase() + Math.random().toString(36).substring(2,4).toUpperCase();
      inviteCodes.push({ code, created_by: userId });
    }
    await sbFetch('invite_codes', {
      method: 'POST',
      prefer: 'return=minimal',
      body: JSON.stringify(inviteCodes)
    });

    // 4. Kullanılan davet kodunu işaretle (master kod için atlıyoruz)
    const isMaster = sessionStorage.getItem('isMasterInvite') === 'true';
    sessionStorage.removeItem('isMasterInvite');
    if (!isMaster) await sbFetch(`invite_codes?code=eq.${encodeURIComponent(inviteCode)}`, {
      method: 'PATCH',
      body: JSON.stringify({ used_by: userId, used_at: new Date().toISOString() })
    });

    // 5. Session kaydet
    sessionStorage.setItem('sb_access_token', accessToken);
    sessionStorage.setItem('sb_refresh_token', authData.refresh_token || '');
    currentUser = authData.user;
    currentProfile = { username, invite_code: newInviteCode, invite_codes: inviteCodes.map(c => c.code) };

    // 6. Davet kodunu welcome ekranında göster
    const codeEl = document.querySelector('.invite-code-value');
    if (codeEl) codeEl.textContent = inviteCodes[0].code;
    sessionStorage.removeItem('pendingInviteCode');

    updateProfileUI();
    goTo('screen-welcome');

  } catch(e) {
    const msg = e.message || '';
    if (msg.includes('already registered') || msg.includes('already been registered')) {
      showToast(lang==='tr'?'Bu e-posta zaten kayıtlı!':'Email already registered!');
    } else {
      showToast(lang==='tr'?`Hata: ${msg}`:`Error: ${msg}`);
    }
    console.warn('[createAccount]', e);
  } finally {
    btn.textContent = lang==='tr'?'Hesap Oluştur →':'Create Account →';
    btn.disabled = false;
  }
}

// Giriş yap
async function signIn() {
  const email    = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;

  if (!email || !password) {
    showToast(lang==='tr'?'E-posta ve şifre gerekli!':'Email and password required!');
    return;
  }

  const btn = document.getElementById('btn-sign-in');
  btn.textContent = lang==='tr'?'Giriş yapılıyor...':'Signing in...';
  btn.disabled = true;

  try {
    const data = await authFetch('token?grant_type=password', {
      method: 'POST',
      body: JSON.stringify({ email, password })
    });

    sessionStorage.setItem('sb_access_token', data.access_token);
    sessionStorage.setItem('sb_refresh_token', data.refresh_token || '');
    currentUser = data.user;

    // Profili yükle
    await loadProfile(data.user.id, data.access_token);
    updateProfileUI();
    goTo('screen-home');

  } catch(e) {
    const msg = e.message || '';
    if (msg.includes('Invalid login')) {
      showToast(lang==='tr'?'E-posta veya şifre hatalı!':'Invalid email or password!');
    } else {
      showToast(lang==='tr'?`Hata: ${msg}`:`Error: ${msg}`);
    }
    console.warn('[signIn]', e);
  } finally {
    btn.textContent = lang==='tr'?'Giriş Yap →':'Sign In →';
    btn.disabled = false;
  }
}

// Profil yükle
async function loadProfile(userId, token) {
  try {
    // Profil bilgilerini yükle
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/profiles?id=eq.${userId}&select=*`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + token, 'Prefer': '' } }
    );
    const data = await res.json();
    if (data && data[0]) {
      currentProfile = data[0];
    }

    // Kullanıcının davet kodlarını yükle
    const invRes = await fetch(
      `${SUPABASE_URL}/rest/v1/invite_codes?created_by=eq.${userId}&select=code,used_by,used_at&order=created_at.asc`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + token, 'Prefer': '' } }
    );
    const invData = await invRes.json();
    if (invData && currentProfile) {
      currentProfile.invite_codes = invData;
    }

    updateInviteCodesUI();
  } catch(e) {
    console.warn('[loadProfile]', e);
  }
}

// Çıkış yap
async function signOut() {
  try {
    const token = sessionStorage.getItem('sb_access_token');
    if (token) {
      await authFetch('logout', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token }
      });
    }
  } catch(e) {}
  sessionStorage.removeItem('sb_access_token');
  sessionStorage.removeItem('sb_refresh_token');
  currentUser = null;
  currentProfile = null;
  goTo('screen-splash');
}

// Session kontrolü — sayfa yenilenince oturumu koru
async function checkSession() {
  const token = sessionStorage.getItem('sb_access_token');
  if (!token) return;
  try {
    const res = await fetch(`${SUPABASE_URL}/auth/v1/user`, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + token }
    });
    if (res.ok) {
      const user = await res.json();
      currentUser = user;
      await loadProfile(user.id, token);
      updateProfileUI();
      loadPlaces();
      goTo('screen-home');
    } else {
      sessionStorage.removeItem('sb_access_token');
    }
  } catch(e) {
    console.warn('[checkSession]', e);
  }
}

// Profil UI güncelle
function updateProfileUI() {
  if (!currentProfile) return;
  const username = currentProfile.username || 'Crew';
  const inviteCode = currentProfile.invite_code || 'CRW-XXX';

  // Avatar baş harfi
  const avatarEls = document.querySelectorAll('.home-avatar, .profile-avatar');
  avatarEls.forEach(el => el.textContent = username.charAt(0).toUpperCase());

  // Profil adı
  const nameEl = document.querySelector('.profile-name');
  if (nameEl) nameEl.textContent = username;

  // Davet kodları
  document.querySelectorAll('.invite-code-value, .invite-code-text').forEach(el => {
    el.textContent = inviteCode;
  });

  // Davet kodlarını güncelle
  updateInviteCodesUI();

  // Yorum kutusunda kullanıcı adını doldur ve kilitle
  const commentInput = document.getElementById('comment-username');
  if (commentInput) {
    commentInput.value = username;
    commentInput.readOnly = true;
    commentInput.style.background = 'var(--cream-dark)';
    commentInput.style.color = 'var(--text-secondary)';
    commentInput.title = lang==='tr' ? 'Giriş yapılan hesap' : 'Logged in account';
  }
}



// ── HARİTA SİSTEMİ (Leaflet + OpenStreetMap) ─────────────────────────────────
let currentMapPlace = null;
let leafletMap = null;

async function openMapModal() {
  const p = places.find(x => x.id === currentDetailId);
  if (!p) return;
  currentMapPlace = p;

  const btn = document.getElementById('map-placeholder-btn');
  if (btn) {
    btn.classList.add('loading');
    btn.innerHTML = '⏳ <span>' + (lang==='tr'?'Konum aranıyor...':'Finding location...') + '</span>';
  }

  try {
    // Nominatim ile adres → koordinat
    const query = encodeURIComponent(`${p.name}, ${p.addr}`);
    const res = await fetch(
      `https://nominatim.openstreetmap.org/search?q=${query}&format=json&limit=1`,
      { headers: { 'Accept-Language': lang } }
    );
    const data = await res.json();

    let lat, lon;
    if (data && data[0]) {
      lat = parseFloat(data[0].lat);
      lon = parseFloat(data[0].lon);
    } else {
      // Fallback: şehir merkezleri
      const cityCoords = {
        'Seoul': [37.5665, 126.9780], 'Tokyo': [35.6762, 139.6503],
        'Istanbul': [41.0082, 28.9784], 'İstanbul': [41.0082, 28.9784],
        'Paris': [48.8566, 2.3522], 'London': [51.5074, -0.1278],
        'Dubai': [25.2048, 55.2708], 'New York': [40.7128, -74.0060],
        'Bangkok': [13.7563, 100.5018], 'Singapore': [1.3521, 103.8198],
      };
      const city = Object.keys(cityCoords).find(c => p.addr.includes(c));
      [lat, lon] = city ? cityCoords[city] : [37.5665, 126.9780];
    }

    showMapModal(p, lat, lon);

  } catch(e) {
    console.warn('[Map]', e);
    showToast(lang==='tr'?'Harita yüklenemedi.':'Could not load map.');
  } finally {
    if (btn) {
      btn.classList.remove('loading');
      btn.innerHTML = '🗺 <span id="map-text">' + (lang==='tr'?'Haritada Göster':'View on Map') + '</span>';
    }
  }
}

function showMapModal(p, lat, lon) {
  // Eski modal varsa kaldır
  const old = document.getElementById('map-modal');
  if (old) old.remove();
  if (leafletMap) { leafletMap.remove(); leafletMap = null; }

  const modal = document.createElement('div');
  modal.id = 'map-modal';
  modal.className = 'map-modal';
  modal.innerHTML = `
    <div class="map-modal-header">
      <button class="map-close-btn" onclick="closeMapModal()">←</button>
      <div>
        <div class="map-modal-title">${p.name}</div>
        <div class="map-modal-addr">📍 ${p.addr}</div>
      </div>
    </div>
    <div id="map-container"></div>
    <div class="map-actions-bar">
      <button class="map-action-btn" onclick="copyAddress('${p.addr}')">📋 ${lang==='tr'?'Adresi Kopyala':'Copy Address'}</button>
      <button class="map-action-btn primary" onclick="openDirections(${lat},${lon},'${p.name.replace(/'/g,"\'")}')">🧭 ${lang==='tr'?'Yol Tarifi':'Directions'}</button>
    </div>
  `;

  document.getElementById('app').appendChild(modal);

  // Leaflet haritayı başlat
  setTimeout(() => {
    leafletMap = L.map('map-container', {
      center: [lat, lon],
      zoom: 16,
      zoomControl: true,
      attributionControl: true
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 19
    }).addTo(leafletMap);

    // Custom marker — navy renk
    const markerIcon = L.divIcon({
      html: `<div style="
        width:36px;height:36px;border-radius:50% 50% 50% 0;
        background:var(--navy,#0f1729);border:3px solid white;
        transform:rotate(-45deg);box-shadow:0 2px 8px rgba(0,0,0,0.3);
        display:flex;align-items:center;justify-content:center;
      "><span style="transform:rotate(45deg);font-size:14px;">${p.emoji}</span></div>`,
      className: '',
      iconSize: [36, 36],
      iconAnchor: [18, 36],
      popupAnchor: [0, -38]
    });

    L.marker([lat, lon], { icon: markerIcon })
      .addTo(leafletMap)
      .bindPopup(`<b>${p.name}</b><br><small>${p.addr}</small>`, {
        closeButton: false, maxWidth: 200
      })
      .openPopup();

    // Haritayı yeniden boyutlandır
    leafletMap.invalidateSize();
  }, 100);
}

function closeMapModal() {
  const modal = document.getElementById('map-modal');
  if (modal) modal.remove();
  if (leafletMap) { leafletMap.remove(); leafletMap = null; }
}

function openDirections(lat, lon, name) {
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
  const isAndroid = /Android/.test(navigator.userAgent);

  if (isIOS) {
    // Apple Maps
    window.open(`maps://maps.apple.com/?daddr=${lat},${lon}&q=${encodeURIComponent(name)}`);
  } else if (isAndroid) {
    // Google Maps
    window.open(`geo:${lat},${lon}?q=${lat},${lon}(${encodeURIComponent(name)})`);
  } else {
    // Desktop — Google Maps web
    window.open(`https://www.google.com/maps/dir/?api=1&destination=${lat},${lon}&destination_place_id=${encodeURIComponent(name)}`);
  }
}

function copyAddress(addr) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText(addr).then(() => {
      showToast(lang==='tr'?'📋 Adres kopyalandı!':'📋 Address copied!');
    });
  } else {
    showToast(addr);
  }
}


// ── GELİŞMİŞ FİLTRELER ───────────────────────────────────────────────────────
let activeFilters = { price: [], rating: null, sort: 'default' };
let currentFilterSection = null;

function openFilterPanel(section) {
  currentFilterSection = section;
  const panel = document.getElementById('filter-panel');
  const overlay = document.getElementById('filter-overlay');
  panel.classList.add('open');
  overlay.classList.add('open');

  // Hangi bölümü öne çıkar
  ['price','rating','sort'].forEach(s => {
    const el = document.getElementById(`filter-${s}-section`);
    if (el) el.style.display = s === section ? '' : 'none';
  });

  const titles = {
    price: { tr:'Fiyat Aralığı', en:'Price Range' },
    rating: { tr:'Minimum Puan', en:'Min Rating' },
    sort: { tr:'Sıralama', en:'Sort By' }
  };
  const t = titles[section];
  if (t) document.getElementById('filter-panel-title').textContent = t[lang] || t.tr;
}

function closeFilterPanel() {
  document.getElementById('filter-panel').classList.remove('open');
  document.getElementById('filter-overlay').classList.remove('open');
  // Tüm bölümleri tekrar göster
  ['price','rating','sort'].forEach(s => {
    const el = document.getElementById(`filter-${s}-section`);
    if (el) el.style.display = '';
  });
}

function toggleFilterOpt(btn, type) {
  if (type === 'sort') {
    // Tek seçim
    document.querySelectorAll('#filter-sort-opts .filter-opt-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    activeFilters.sort = btn.dataset.val;
  } else if (type === 'price') {
    // Çok seçim
    btn.classList.toggle('selected');
    const val = btn.dataset.val;
    if (btn.classList.contains('selected')) {
      if (!activeFilters.price.includes(val)) activeFilters.price.push(val);
    } else {
      activeFilters.price = activeFilters.price.filter(v => v !== val);
    }
  }
  updateFilterChips();
}

function selectRatingFilter(btn) {
  const wasSelected = btn.classList.contains('selected');
  document.querySelectorAll('#filter-rating-opts .filter-rating-btn').forEach(b => b.classList.remove('selected'));
  if (!wasSelected) {
    btn.classList.add('selected');
    activeFilters.rating = parseFloat(btn.dataset.val);
  } else {
    activeFilters.rating = null;
  }
  updateFilterChips();
}

function updateFilterChips() {
  const chipLabels = {
    price: {tr:'Fiyat',en:'Price',de:'Preis',fr:'Prix',es:'Precio',ar:'السعر',ja:'価格',ko:'가격',zh:'价格'},
    rating: {tr:'Puan',en:'Rating',de:'Bewertung',fr:'Note',es:'Calificación',ar:'التقييم',ja:'評価',ko:'평점',zh:'评分'},
    sort: {tr:'Sırala',en:'Sort',de:'Sortieren',fr:'Trier',es:'Ordenar',ar:'ترتيب',ja:'並替',ko:'정렬',zh:'排序'},
  };
  const sortLabels = {
    default: {tr:'Sırala',en:'Sort',de:'Sortieren',fr:'Trier',es:'Ordenar',ar:'ترتيب',ja:'並替',ko:'정렬',zh:'排序'},
    rating: {tr:'En Yüksek ⭐',en:'Top Rated ⭐',de:'Beste ⭐',fr:'Mieux noté ⭐',es:'Mejor valorado ⭐',ar:'الأعلى ⭐',ja:'高評価 ⭐',ko:'높은 평점 ⭐',zh:'最高评分 ⭐'},
    likes: {tr:'En Beğenilen ♥',en:'Most Liked ♥',de:'Beliebteste ♥',fr:'Plus aimé ♥',es:'Más gustado ♥',ar:'الأكثر إعجاباً ♥',ja:'人気 ♥',ko:'인기 ♥',zh:'最受欢迎 ♥'},
    newest: {tr:'En Yeni 🆕',en:'Newest 🆕',de:'Neueste 🆕',fr:'Plus récent 🆕',es:'Más nuevo 🆕',ar:'الأحدث 🆕',ja:'最新 🆕',ko:'최신 🆕',zh:'最新 🆕'},
  };
  const l = lang || 'tr';

  // Fiyat chip
  const priceChip = document.getElementById('chip-price');
  const priceLabel = document.getElementById('chip-price-label');
  if (activeFilters.price.length > 0) {
    priceChip.classList.add('has-value');
    priceLabel.textContent = activeFilters.price.join(', ');
  } else {
    priceChip.classList.remove('has-value');
    priceLabel.textContent = (chipLabels.price[l] || chipLabels.price.en);
  }

  // Puan chip
  const ratingChip = document.getElementById('chip-rating');
  const ratingLabel = document.getElementById('chip-rating-label');
  if (activeFilters.rating) {
    ratingChip.classList.add('has-value');
    ratingLabel.textContent = `${activeFilters.rating}+ ⭐`;
  } else {
    ratingChip.classList.remove('has-value');
    ratingLabel.textContent = (chipLabels.rating[l] || chipLabels.rating.en);
  }

  // Sıralama chip
  const sortChip = document.getElementById('chip-sort');
  const sortLabel = document.getElementById('chip-sort-label');
  if (activeFilters.sort !== 'default') {
    sortChip.classList.add('has-value');
    sortLabel.textContent = (sortLabels[activeFilters.sort] || sortLabels.default)[l] || (sortLabels[activeFilters.sort] || sortLabels.default).en;
  } else {
    sortChip.classList.remove('has-value');
    sortLabel.textContent = (chipLabels.sort[l] || chipLabels.sort.en);
  }

  // Temizle butonu
  const hasAny = activeFilters.price.length > 0 || activeFilters.rating || activeFilters.sort !== 'default';
  document.getElementById('chip-reset').style.display = hasAny ? '' : 'none';
}

function applyFilters() {
  renderCards();
}

function resetFilters() {
  activeFilters = { price: [], rating: null, sort: 'default' };
  // UI sıfırla
  document.querySelectorAll('.filter-opt-btn').forEach(b => b.classList.remove('selected'));
  const defSort = document.querySelector('[data-val="default"]');
  if (defSort) defSort.classList.add('selected');
  document.querySelectorAll('.filter-rating-btn').forEach(b => b.classList.remove('selected'));
  updateFilterChips();
  renderCards();
}


// ── ADMİN FONKSİYONLARI ──────────────────────────────────────────────────────
async function adminDeletePlace() {
  if (!isAdmin()) { showToast('Yetkisiz işlem!'); return; }
  const p = places.find(x => x.id === currentDetailId);
  if (!p) return;

  const confirmed = confirm(
    lang==='tr'
      ? `"${p.name}" yerini kaldırmak istediğinden emin misin?`
      : `Are you sure you want to remove "${p.name}"?`
  );
  if (!confirmed) return;

  try {
    const token = sessionStorage.getItem('sb_access_token');
    const res = await fetch(SUPABASE_URL + '/rest/v1/places?id=eq.' + p.id, {
      method: 'PATCH',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + (token || SUPABASE_KEY),
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({ is_hidden: true })
    });
    if (!res.ok) {
      console.warn('[adminDelete]', await res.text());
    }
  } catch(e) {
    console.warn('[adminDelete Supabase]', e);
  }

  // Yerel listeden kaldır
  const idx = places.findIndex(x => x.id === currentDetailId);
  if (idx !== -1) places.splice(idx, 1);

  showToast(lang==='tr' ? `🗑 "${p.name}" kaldırıldı.` : `🗑 "${p.name}" removed.`);
  renderCards();
  goTo('screen-home');
}

async function adminHideComment(commentId) {
  if (!isAdmin()) return;
  try {
    await sbFetch(`comments?id=eq.${commentId}`, {
      method: 'PATCH',
      body: JSON.stringify({ text: '[Bu yorum kaldırılmıştır.]' })
    });
    await loadComments(commentPlaceId);
    showToast(lang==='tr'?'Yorum kaldırıldı.':'Comment removed.');
  } catch(e) {
    console.warn('[adminHideComment]', e);
  }
}


// ── KULLANICI ADI DEĞİŞTİR ────────────────────────────────────────────────────
async function changeUsername() {
  const input = document.getElementById('settings-username-input');
  const newUsername = input ? input.value.trim() : '';

  if (!newUsername) { showToast(lang==='tr'?'Kullanıcı adı boş olamaz!':'Username cannot be empty!'); return; }
  if (newUsername.length < 3) { showToast(lang==='tr'?'En az 3 karakter!':'At least 3 characters!'); return; }
  if (newUsername.length > 30) { showToast(lang==='tr'?'En fazla 30 karakter!':'Max 30 characters!'); return; }
  if (!/^[a-zA-Z0-9_çğışöüÇĞİŞÖÜ]+$/.test(newUsername)) {
    showToast(lang==='tr'?'Sadece harf, rakam ve _ kullanılabilir!':'Only letters, numbers and _ allowed!');
    return;
  }
  if (!currentUser) { showToast(lang==='tr'?'Giriş yapman gerekli!':'Please sign in!'); return; }

  const btn = document.getElementById('btn-change-username');
  if (btn) { btn.textContent = lang==='tr'?'Kaydediliyor...':'Saving...'; btn.disabled = true; }

  try {
    // Başka biri kullanıyor mu kontrol et
    const existing = await sbFetch(
      `profiles?username=eq.${encodeURIComponent(newUsername)}&id=neq.${currentUser.id}&select=id`,
      { headers: { 'Prefer': '' } }
    );
    if (existing && existing.length > 0) {
      showToast(lang==='tr'?'Bu kullanıcı adı alınmış!':'Username already taken!');
      return;
    }

    // Güncelle
    const token = sessionStorage.getItem('sb_access_token');
    const res = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${currentUser.id}`, {
      method: 'PATCH',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': 'Bearer ' + (token || SUPABASE_KEY),
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({ username: newUsername })
    });

    if (!res.ok) throw new Error(await res.text());

    // Yerel profili güncelle
    if (currentProfile) currentProfile.username = newUsername;
    updateProfileUI();

    // Yorum input'unu da güncelle
    const commentInput = document.getElementById('comment-username');
    if (commentInput) commentInput.value = newUsername;

    // Input'u temizle
    if (input) input.value = '';
    updateCurrentUsernameDisplay();

    showToast(lang==='tr'?`✓ Kullanıcı adı "${newUsername}" olarak güncellendi!`:`✓ Username updated to "${newUsername}"!`);

  } catch(e) {
    showToast(lang==='tr'?'Güncelleme başarısız.':'Update failed.');
    console.warn('[changeUsername]', e);
  } finally {
    if (btn) { btn.textContent = lang==='tr'?'Kaydet':'Save'; btn.disabled = false; }
  }
}

function updateCurrentUsernameDisplay() {
  const el = document.getElementById('current-username-display');
  if (el && currentProfile) {
    el.textContent = (lang==='tr'?'Mevcut: ':'Current: ') + currentProfile.username;
  }
}


// ── YER EKLEME — GPS KONUM ────────────────────────────────────────────────────
async function fillCurrentLocation() {
  const btn = document.getElementById('btn-gps-location');
  const status = document.getElementById('gps-status');
  const input = document.getElementById('input-place-addr');

  if (!navigator.geolocation) {
    showToast(lang==='tr'?'Tarayıcın konum desteklemiyor.':'Geolocation not supported.');
    return;
  }

  // Loading durumu
  if (btn) { btn.textContent = '⏳'; btn.style.opacity = '0.6'; btn.disabled = true; }
  if (status) { status.style.display = 'block'; status.textContent = lang==='tr'?'📡 Konum alınıyor...':'📡 Getting location...'; }

  navigator.geolocation.getCurrentPosition(
    async (pos) => {
      const { latitude: lat, longitude: lon, accuracy } = pos.coords;
      try {
        // Nominatim ile koordinat → adres
        const res = await fetch(
          `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&accept-language=${lang}`,
          { headers: { 'User-Agent': 'CrewGuide/1.0' } }
        );
        const data = await res.json();

        // En anlamlı adresi oluştur
        const a = data.address || {};
        const parts = [];
        if (a.road || a.pedestrian || a.street) parts.push(a.road || a.pedestrian || a.street);
        if (a.neighbourhood || a.suburb || a.district) parts.push(a.neighbourhood || a.suburb || a.district);
        if (a.city || a.town || a.village || a.county) parts.push(a.city || a.town || a.village || a.county);
        if (a.country) parts.push(a.country);

        const addr = parts.join(', ') || data.display_name || `${lat.toFixed(5)}, ${lon.toFixed(5)}`;

        if (input) input.value = addr;
        if (status) {
          status.textContent = `✓ ${lang==='tr'?'Konum alındı':'Location found'} (~${Math.round(accuracy)}m ${lang==='tr'?'hassasiyet':'accuracy'})`;
          status.style.color = '#10b981';
          setTimeout(() => { if (status) status.style.display = 'none'; }, 3000);
        }
        showToast(lang==='tr'?'📍 Konum eklendi!':'📍 Location added!');

      } catch(e) {
        // Nominatim hatası — koordinatı direkt yaz
        if (input) input.value = `${lat.toFixed(5)}, ${lon.toFixed(5)}`;
        if (status) { status.textContent = lang==='tr'?'⚠️ Adres çözümlenemedi, koordinat eklendi.':'⚠️ Address lookup failed, coordinates added.'; status.style.color = '#f59e0b'; }
        console.warn('[GPS reverse geocode]', e);
      } finally {
        if (btn) { btn.textContent = '📍'; btn.style.opacity = '1'; btn.disabled = false; }
      }
    },
    (err) => {
      if (btn) { btn.textContent = '📍'; btn.style.opacity = '1'; btn.disabled = false; }
      const msgs = {
        1: { tr:'Konum izni reddedildi. Tarayıcı ayarlarından izin ver.', en:'Location permission denied. Enable in browser settings.' },
        2: { tr:'Konum alınamadı. Tekrar dene.', en:'Could not get location. Try again.' },
        3: { tr:'Konum zaman aşımına uğradı.', en:'Location request timed out.' },
      };
      const msg = msgs[err.code] || { tr:'Konum hatası.', en:'Location error.' };
      if (status) { status.style.display = 'block'; status.textContent = '⚠️ ' + msg[lang]; status.style.color = '#ef4444'; }
      showToast(msg[lang]);
    },
    { enableHighAccuracy: true, timeout: 10000, maximumAge: 30000 }
  );
}


// ── SUPABASE'DEN YERLERİ YÜKLE ───────────────────────────────────────────────
async function loadPlaces(cityFilter) {
  try {
    const city = cityFilter || currentCity || null;
    let query = 'places?is_hidden=eq.false&order=created_at.desc&limit=100';
    if (city) {
      query += '&addr=ilike.*' + encodeURIComponent(city) + '*';
    }
    const data = await sbFetch(query, { headers: { 'Prefer': '' } });

    // Şehir değişince tüm yerleri temizle, Supabase'den taze yükle
    places.length = 0;

    if (!data || data.length === 0) {
      renderCards();
      return;
    }

    // Supabase'den gelen yerleri places dizisine ekle (duplicate olmaması için)
    const existingIds = new Set(places.map(p => p.id));
    const priceName = {
      '$':  { tr:'Uygun',  en:'Budget' },
      '$$': { tr:'Orta',   en:'Mid-range' },
      '$$$':{ tr:'Pahalı', en:'Expensive' }
    };

    data.forEach(row => {
      if (existingIds.has(row.id)) return; // zaten varsa atla
      places.push({
        id: row.id,
        cat: row.cat,
        subcat: row.subcat || '',
        emoji: row.emoji || '📍',
        name: row.name,
        addr: row.addr || '',
        price: row.price || '$',
        priceName: priceName[row.price] || { tr:'Uygun', en:'Budget' },
        likes: row.likes || 0,
        rating: parseFloat(row.rating) || 0,
        ratingCount: row.rating_count || 0,
        ratings: { 5:0, 4:0, 3:0, 2:0, 1:0 },
        userRating: 0,
        isAdult: row.is_adult || false,
        userId: row.user_id || null,
        desc: { tr: row.desc_tr || '', en: row.desc_en || '' }
      });
    });

    renderCards();
    console.log(`[Places] ${data.length} yer Supabase'den yüklendi.`);
  } catch(e) {
    console.warn('[loadPlaces]', e);
  }
}


// ── DAVET KODLARI UI ──────────────────────────────────────────────────────────
function updateInviteCodesUI() {
  if (!currentProfile || !currentProfile.invite_codes) return;
  const codes = currentProfile.invite_codes;

  // Profil ekranındaki davet bölümünü güncelle
  const inviteDisplay = document.querySelector('.invite-display');
  if (!inviteDisplay) return;

  const used = codes.filter(c => c.used_by).length;
  const total = codes.length;
  const remaining = total - used;

  inviteDisplay.innerHTML = `
    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:10px;">
      ${codes.map(c => `
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">
          <div>
            <div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;color:${c.used_by ? 'var(--text-muted)' : 'var(--navy)'};">
              ${c.code}
            </div>
            <div style="font-size:10px;color:var(--text-muted);margin-top:2px;">
              ${c.used_by
                ? (lang==='tr'?'✓ Kullanıldı':'✓ Used')
                : (lang==='tr'?'Kullanılabilir':'Available')}
            </div>
          </div>
          ${!c.used_by ? `
            <button onclick="copyInviteCode('${c.code}')" style="
              font-size:11px;background:var(--navy);color:#fff;
              border:none;border-radius:6px;padding:5px 12px;cursor:pointer;
              font-family:'DM Sans',sans-serif;">
              ${lang==='tr'?'Kopyala':'Copy'}
            </button>` : `<span style="font-size:16px;">✓</span>`}
        </div>
      `).join('')}
    </div>
    <div class="quota-text" id="quota-text">
      ${lang==='tr'
        ? `${used} kişiyi davet ettin · ${remaining} hakkın kaldı`
        : `You invited ${used} · ${remaining} remaining`}
    </div>
    <div class="quota-bar">
      <div class="quota-fill" style="width:${total > 0 ? (used/total)*100 : 0}%"></div>
    </div>
  `;
}

function copyInviteCode(code) {
  if (navigator.clipboard) {
    navigator.clipboard.writeText(code).then(() => {
      showToast(lang==='tr'?`"${code}" kopyalandı!`:`"${code}" copied!`);
    });
  } else {
    showToast(code);
  }
}


// ── DİL DROPDOWN ─────────────────────────────────────────────────────────────
const langMeta = {
  tr: { flag: '🇹🇷', name: 'Türkçe' },
  en: { flag: '🇬🇧', name: 'English' },
  de: { flag: '🇩🇪', name: 'Deutsch' },
  fr: { flag: '🇫🇷', name: 'Français' },
  es: { flag: '🇪🇸', name: 'Español' },
  ar: { flag: '🇦🇪', name: 'العربية' },
  ja: { flag: '🇯🇵', name: '日本語' },
  ko: { flag: '🇰🇷', name: '한국어' },
  zh: { flag: '🇨🇳', name: '中文' },
};

function toggleLangDropdown() {
  const btn = document.getElementById('lang-dropdown-btn');
  const menu = document.getElementById('lang-dropdown-menu');
  if (!btn || !menu) return;
  btn.classList.toggle('open');
  menu.classList.toggle('open');
}

function selectLang(l) {
  // Dropdown'ı kapat
  const btn = document.getElementById('lang-dropdown-btn');
  const menu = document.getElementById('lang-dropdown-menu');
  if (btn) btn.classList.remove('open');
  if (menu) menu.classList.remove('open');

  // Buton metnini güncelle
  updateLangBtn(l);

  // Dili uygula
  setLangFromSettings(l);
}

function updateLangBtn(l) {
  const meta = langMeta[l];
  if (!meta) return;
  const flagEl = document.getElementById('lang-btn-flag');
  const nameEl = document.getElementById('lang-btn-name');
  if (flagEl) flagEl.textContent = meta.flag;
  if (nameEl) nameEl.textContent = meta.name;

  // Aktif option'ı işaretle
  document.querySelectorAll('.lang-option').forEach(opt => {
    opt.classList.toggle('active', opt.dataset.lang === l);
  });
}

// Dropdown dışına tıklayınca kapat
document.addEventListener('click', (e) => {
  const wrapper = document.querySelector('.lang-dropdown-wrapper');
  if (wrapper && !wrapper.contains(e.target)) {
    document.getElementById('lang-dropdown-btn')?.classList.remove('open');
    document.getElementById('lang-dropdown-menu')?.classList.remove('open');
  }
});

// Init — kayıtlı dili yükle
const savedLang = localStorage.getItem('crewguide_lang');
if (savedLang && translations[savedLang]) {
  lang = savedLang;
  document.documentElement.dir = savedLang === 'ar' ? 'rtl' : 'ltr';
  document.querySelectorAll('.lang-setting-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.lang === savedLang);
  });
  // Dropdown butonunu güncelle
  setTimeout(() => updateLangBtn(savedLang), 0);
  applyTranslations();
}
renderCards();
renderSubCats();
updateCurrencyBadge('Seoul');
// Supabase'den Seoul yerlerini yükle
loadPlaces('Seoul');
// Sayfa yüklenince session kontrol et
window.addEventListener('load', () => {
  checkSession();
});

function updateCurrencyBadge(cityName) {
  const cur = getCurrencyForCity(cityName);
  currentCurrency = cur;
  const symEl = document.getElementById('currency-symbol');
  const codeEl = document.getElementById('currency-code');
  if (symEl) symEl.textContent = cur.symbol;
  if (codeEl) codeEl.textContent = cur.code;
}

function showCurrencyInfo() {
  const cur = currentCurrency;
  const usdRate = (1 / cur.rate).toFixed(2);
  const msg = lang === 'tr'
    ? `${cur.name.tr} (${cur.code})\n1 USD ≈ ${usdRate} ${cur.symbol}`
    : `${cur.name.en} (${cur.code})\n1 USD ≈ ${usdRate} ${cur.symbol}`;
  // Küçük bilgi modal
  showCurrencyModal(cur);
}

function showCurrencyModal(cur) {
  // Mevcut modal varsa kaldır
  const old = document.getElementById('currency-modal');
  if (old) old.remove();

  const usdRate = (1 / cur.rate).toFixed(1);
  const examples = [
    { label: lang==='tr'?'Ucuz yemek':'Budget meal', usd: 15 },
    { label: lang==='tr'?'Orta restoran':'Mid restaurant', usd: 40 },
    { label: lang==='tr'?'Pahalı restoran':'Fine dining', usd: 90 },
    { label: lang==='tr'?'Taksi (5 km)':'Taxi (5 km)', usd: 8 },
    { label: lang==='tr'?'Kafe kahve':'Café coffee', usd: 5 },
  ];

  const rows = examples.map(e =>
    `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">
      <span style="font-size:13px;color:var(--text-secondary);">${e.label}</span>
      <span style="font-size:13px;font-weight:600;color:var(--text-primary);">${formatLocalPrice(e.usd, cur)}</span>
    </div>`
  ).join('');

  const modal = document.createElement('div');
  modal.id = 'currency-modal';
  modal.style.cssText = 'position:absolute;inset:0;background:rgba(0,0,0,0.5);z-index:150;display:flex;align-items:flex-end;justify-content:center;';
  modal.innerHTML = `
    <div style="background:var(--cream);border-radius:24px 24px 0 0;padding:20px;width:100%;max-height:80vh;overflow-y:auto;">
      <div style="width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px;"></div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
        <div style="width:42px;height:42px;border-radius:12px;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--gold);">${cur.symbol}</div>
        <div>
          <div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--text-primary);">${lang==='tr'?cur.name.tr:cur.name.en}</div>
          <div style="font-size:11px;color:var(--text-muted);">1 USD ≈ ${usdRate} ${cur.symbol} · ${cur.code}</div>
        </div>
      </div>
      <div style="font-family:'Syne',sans-serif;font-size:12px;font-weight:600;color:var(--text-secondary);margin:16px 0 4px;">${lang==='tr'?'Yaklaşık Fiyat Rehberi':'Approximate Price Guide'}</div>
      ${rows}
      <div style="font-size:10px;color:var(--text-muted);margin-top:10px;text-align:center;">${lang==='tr'?'Kurlar yaklaşık değerdir, değişebilir.':'Rates are approximate and may vary.'}</div>
      <button onclick="document.getElementById('currency-modal').remove()" style="width:100%;margin-top:14px;padding:13px;border-radius:14px;background:var(--navy);color:var(--white);font-family:'Syne',sans-serif;font-size:14px;font-weight:600;border:none;cursor:pointer;">${lang==='tr'?'Tamam':'OK'}</button>
    </div>`;
  modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
  document.getElementById('app').appendChild(modal);
}

// ─── PWA: SERVICE WORKER KAYDI ────────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js', { scope: './' })
      .then(reg => {
        console.log('[PWA] SW kayıtlı, scope:', reg.scope);
        reg.addEventListener('updatefound', () => {
          const newWorker = reg.installing;
          newWorker.addEventListener('statechange', () => {
            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
              showUpdateBanner();
            }
          });
        });
      })
      .catch(err => console.warn('[PWA] SW kaydı başarısız:', err));

    navigator.serviceWorker.addEventListener('message', event => {
      if (event.data && event.data.type === 'CITY_CACHED') {
        showToast(lang === 'tr'
          ? `${event.data.cityName} çevrimdışı kullanıma hazır ✓`
          : `${event.data.cityName} ready for offline use ✓`);
      }
      if (event.data?.type === 'NOTIF_CLICK') {
        goTo('screen-home');
      }
    });
  });
}

// ─── PWA: GÜNCELLEME BANNER ───────────────────────────────────────────────────
function showUpdateBanner() {
  const t = document.getElementById('toast');
  t.innerHTML = (lang === 'tr' ? 'Yeni sürüm var! ' : 'Update available! ') +
    '<span onclick="applyUpdate()" style="text-decoration:underline;cursor:pointer;font-weight:700;">' +
    (lang === 'tr' ? 'Güncelle' : 'Refresh') + '</span>';
  t.classList.add('show');
}

function applyUpdate() {
  if (navigator.serviceWorker.controller) {
    navigator.serviceWorker.controller.postMessage('skipWaiting');
  }
  window.location.reload();
}

// ─── PWA: ANA EKRANA EKLE (Install Prompt) ───────────────────────────────────
let deferredInstallPrompt = null;

window.addEventListener('beforeinstallprompt', event => {
  event.preventDefault();
  deferredInstallPrompt = event;
  showInstallButton();
});

window.addEventListener('appinstalled', () => {
  deferredInstallPrompt = null;
  hideInstallButton();
  showToast(lang === 'tr' ? '✓ CrewGuide yüklendi!' : '✓ CrewGuide installed!');
});

function showInstallButton() {
  if (document.getElementById('pwa-install-btn')) return;
  const btn = document.createElement('button');
  btn.id = 'pwa-install-btn';
  btn.onclick = triggerInstall;
  btn.style.cssText = 'width:100%;padding:14px;border-radius:16px;background:var(--gold);color:var(--navy);font-family:Syne,sans-serif;font-size:15px;font-weight:600;border:none;cursor:pointer;margin:0 0 12px;';
  btn.innerHTML = '📲 ' + (lang === 'tr' ? 'Uygulamayı Telefona Yükle' : 'Install App');
  const profileBody = document.querySelector('#screen-profile-view .profile-body');
  if (profileBody) profileBody.insertBefore(btn, profileBody.firstChild);
  const splashBottom = document.querySelector('.splash-bottom');
  if (splashBottom) {
    const s = btn.cloneNode(true);
    s.id = 'pwa-install-btn-splash';
    s.onclick = triggerInstall;
    splashBottom.insertBefore(s, splashBottom.firstChild);
  }
}

function hideInstallButton() {
  ['pwa-install-btn', 'pwa-install-btn-splash'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.remove();
  });
}

function triggerInstall() {
  if (!deferredInstallPrompt) {
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    if (isIOS) {
      showToast(lang === 'tr' ? '📲 Safari\'de "Paylaş" → "Ana Ekrana Ekle"' : '📲 Safari: "Share" → "Add to Home Screen"');
      return;
    }
    showToast(lang === 'tr' ? 'Tarayıcı yüklemeyi desteklemiyor.' : 'Browser install not supported.');
    return;
  }
  deferredInstallPrompt.prompt();
  deferredInstallPrompt.userChoice.then(choice => {
    deferredInstallPrompt = null;
  });
}

// ─── PWA: ONLINE/OFFLINE DURUM ───────────────────────────────────────────────
window.addEventListener('online', () => {
  showToast(lang === 'tr' ? '✓ İnternet bağlantısı geri geldi' : '✓ Back online');
});
window.addEventListener('offline', () => {
  showToast(lang === 'tr' ? '📡 Çevrimdışı — cached veriler kullanılıyor' : '📡 Offline — using cached data');
  const dot = document.getElementById('location-dot');
  if (dot) dot.style.background = '#f59e0b';
});
</script>
</body>
</html>
