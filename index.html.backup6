  <!-- SCREEN: SETTINGS -->
  <div class="screen" id="screen-settings">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header" id="settings-header">
      <div class="nav-back" onclick="goTo('screen-profile-view')">← </div>
      <div class="header-title font-display" id="settings-title">Ayarlar</div>
      <div class="header-sub" id="settings-sub">Görünümü kişiselleştir</div>
    </div>
    <div style="padding:20px;display:flex;flex-direction:column;gap:20px;">

      <!-- DİL SEÇİMİ -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div id="lang-section-title" style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);">🌐 Dil / Language</div>
        </div>
        <div style="padding:12px 16px;display:flex;flex-wrap:wrap;gap:6px;" id="settings-lang-grid">
          <button onclick="setLangFromSettings('tr')" class="lang-setting-btn" data-lang="tr">🇹🇷 Türkçe</button>
          <button onclick="setLangFromSettings('en')" class="lang-setting-btn" data-lang="en">🇬🇧 English</button>
          <button onclick="setLangFromSettings('de')" class="lang-setting-btn" data-lang="de">🇩🇪 Deutsch</button>
          <button onclick="setLangFromSettings('fr')" class="lang-setting-btn" data-lang="fr">🇫🇷 Français</button>
          <button onclick="setLangFromSettings('es')" class="lang-setting-btn" data-lang="es">🇪🇸 Español</button>
          <button onclick="setLangFromSettings('ar')" class="lang-setting-btn" data-lang="ar">🇦🇪 العربية</button>
          <button onclick="setLangFromSettings('ja')" class="lang-setting-btn" data-lang="ja">🇯🇵 日本語</button>
          <button onclick="setLangFromSettings('ko')" class="lang-setting-btn" data-lang="ko">🇰🇷 한국어</button>
          <button onclick="setLangFromSettings('zh')" class="lang-setting-btn" data-lang="zh">🇨🇳 中文</button>
        </div>
      </div>

      <!-- DARK/LIGHT MODE -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);" id="settings-mode-title">Mod</div>
        </div>
        <div style="padding:12px 16px;display:flex;gap:10px;">
          <div id="btn-light" onclick="setMode('light')" style="flex:1;padding:14px;border-radius:var(--radius-sm);border:2px solid var(--navy);background:var(--cream);text-align:center;cursor:pointer;transition:all 0.2s;">
            <div style="font-size:22px;margin-bottom:4px;">☀️</div>
            <div style="font-size:12px;font-weight:500;color:var(--text-primary);" id="label-light">Açık</div>
          </div>
          <div id="btn-dark" onclick="setMode('dark')" style="flex:1;padding:14px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--white);text-align:center;cursor:pointer;transition:all 0.2s;">
            <div style="font-size:22px;margin-bottom:4px;">🌙</div>
            <div style="font-size:12px;font-weight:500;color:var(--text-primary);" id="label-dark">Koyu</div>
          </div>
        </div>
      </div>

      <!-- ACCENT COLOR -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);" id="settings-accent-title">Vurgu Rengi</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;" id="settings-accent-sub">Butonlar ve başlıklarda kullanılır</div>
        </div>
        <div style="padding:16px;">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <div id="accent-preview" style="width:48px;height:48px;border-radius:12px;background:var(--gold);flex-shrink:0;"></div>
            <div style="flex:1;">
              <input type="color" id="accent-picker" value="#c9a84c"
                style="width:100%;height:36px;border:1.5px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;background:none;padding:2px;"
                oninput="applyAccent(this.value)">
            </div>
          </div>
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;" id="label-presets">Hazır renkler</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <div onclick="applyAccent('#c9a84c');document.getElementById('accent-picker').value='#c9a84c'" style="width:32px;height:32px;border-radius:8px;background:#c9a84c;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#0f1729');document.getElementById('accent-picker').value='#0f1729'" style="width:32px;height:32px;border-radius:8px;background:#0f1729;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#2563eb');document.getElementById('accent-picker').value='#2563eb'" style="width:32px;height:32px;border-radius:8px;background:#2563eb;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#16a34a');document.getElementById('accent-picker').value='#16a34a'" style="width:32px;height:32px;border-radius:8px;background:#16a34a;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#dc2626');document.getElementById('accent-picker').value='#dc2626'" style="width:32px;height:32px;border-radius:8px;background:#dc2626;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#9333ea');document.getElementById('accent-picker').value='#9333ea'" style="width:32px;height:32px;border-radius:8px;background:#9333ea;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#0891b2');document.getElementById('accent-picker').value='#0891b2'" style="width:32px;height:32px;border-radius:8px;background:#0891b2;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
            <div onclick="applyAccent('#ea580c');document.getElementById('accent-picker').value='#ea580c'" style="width:32px;height:32px;border-radius:8px;background:#ea580c;cursor:pointer;border:2px solid transparent;" class="preset-dot"></div>
          </div>
        </div>
      </div>

      <!-- BG COLOR -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);" id="settings-bg-title">Arka Plan Rengi</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;" id="settings-bg-sub">Genel sayfa arka planı</div>
        </div>
        <div style="padding:16px;">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <div id="bg-preview" style="width:48px;height:48px;border-radius:12px;background:var(--cream);flex-shrink:0;border:1px solid var(--border);"></div>
            <div style="flex:1;">
              <input type="color" id="bg-picker" value="#f5f0e8"
                style="width:100%;height:36px;border:1.5px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;background:none;padding:2px;"
                oninput="applyBg(this.value)">
            </div>
          </div>
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;" id="label-bg-presets">Hazır renkler</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <div onclick="applyBg('#f5f0e8');document.getElementById('bg-picker').value='#f5f0e8'" style="width:32px;height:32px;border-radius:8px;background:#f5f0e8;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
            <div onclick="applyBg('#ffffff');document.getElementById('bg-picker').value='#ffffff'" style="width:32px;height:32px;border-radius:8px;background:#ffffff;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
            <div onclick="applyBg('#f0f4ff');document.getElementById('bg-picker').value='#f0f4ff'" style="width:32px;height:32px;border-radius:8px;background:#f0f4ff;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
            <div onclick="applyBg('#f0fdf4');document.getElementById('bg-picker').value='#f0fdf4'" style="width:32px;height:32px;border-radius:8px;background:#f0fdf4;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
            <div onclick="applyBg('#fdf4ff');document.getElementById('bg-picker').value='#fdf4ff'" style="width:32px;height:32px;border-radius:8px;background:#fdf4ff;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
            <div onclick="applyBg('#fff7ed');document.getElementById('bg-picker').value='#fff7ed'" style="width:32px;height:32px;border-radius:8px;background:#fff7ed;cursor:pointer;border:1px solid #ccc;" class="preset-dot"></div>
          </div>
        </div>
      </div>

      <!-- RESET -->
      <!-- BİLDİRİM AYARI -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);" id="settings-notif-title">Bildirimler</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;" id="settings-notif-sub">Yeni yerler ve yorumlar için</div>
        </div>
        <div style="padding:14px 16px;display:flex;align-items:center;justify-content:space-between;">
          <span id="notif-status-text" style="font-size:13px;color:var(--text-muted);">⏳ İzin bekleniyor</span>
          <button onclick="grantNotifPermission()" style="
            padding:7px 16px;border-radius:8px;
            background:var(--navy);color:var(--white);
            font-size:12px;font-family:'Syne',sans-serif;font-weight:600;
            border:none;cursor:pointer;" id="btn-notif-settings">
            <span id="btn-notif-text">İzin Ver</span>
          </button>
        </div>
      </div>

      <!-- KULLANICI ADI DEĞİŞTİR -->
      <div style="background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
          <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--text-primary);" id="settings-username-title">Kullanıcı Adı</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;" id="settings-username-sub">Diğer kullanıcılara bu ad görünür</div>
        </div>
        <div style="padding:14px 16px;display:flex;flex-direction:column;gap:10px;">
          <div style="display:flex;gap:8px;align-items:center;">
            <input type="text" id="settings-username-input"
              style="flex:1;padding:10px 12px;background:var(--cream);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;color:var(--text-primary);"
              placeholder="Yeni kullanıcı adı" maxlength="30" autocomplete="off"
              onfocus="this.style.borderColor='var(--navy)'"
              onblur="this.style.borderColor='var(--border)'">
            <button onclick="changeUsername()" style="
              padding:10px 16px;border-radius:var(--radius-sm);
              background:var(--navy);color:#fff;
              font-family:'Syne',sans-serif;font-size:12px;font-weight:600;
              border:none;cursor:pointer;white-space:nowrap;" id="btn-change-username">
              <span id="btn-save-username-text">Kaydet</span>
            </button>
          </div>
          <div style="font-size:11px;color:var(--text-muted);" id="current-username-display"></div>
        </div>
      </div>

      <button onclick="resetTheme()" style="width:100%;padding:14px;border-radius:var(--radius);border:1.5px solid var(--border);background:transparent;font-size:13px;color:var(--text-muted);cursor:pointer;font-family:'DM Sans',sans-serif;" id="btn-reset-theme">↺ Varsayılana Sıfırla</button>
      <button onclick="signOut()" style="width:100%;padding:14px;border-radius:var(--radius);border:1.5px solid #fca5a5;background:transparent;font-size:13px;color:#ef4444;cursor:pointer;font-family:'DM Sans',sans-serif;" id="btn-sign-out">🚪 Çıkış Yap</button>
      <div style="height:20px;"></div>
    </div>
  </div>

</div>

