<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>CrewGuide</title>

<!-- PWA: Manifest -->
<link rel="manifest" href="/manifest.json">

<!-- PWA: Theme & Status Bar -->
<meta name="theme-color" content="#0f1729">
<meta name="mobile-web-app-capable" content="yes">

<!-- iOS PWA -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="CrewGuide">
<link rel="apple-touch-icon" href="./icons/icon-192.png">
<link rel="apple-touch-icon" sizes="152x152" href="./icons/icon-152.png">
<link rel="apple-touch-icon" sizes="144x144" href="./icons/icon-144.png">

<!-- iOS Splash Screens (iPhone 14 Pro / 15) -->
<link rel="apple-touch-startup-image"
  href="./icons/splash-1179x2556.png"
  media="(device-width: 393px) and (device-height: 852px) and (-webkit-device-pixel-ratio: 3)">
<link rel="apple-touch-startup-image"
  href="./icons/splash-1170x2532.png"
  media="(device-width: 390px) and (device-height: 844px) and (-webkit-device-pixel-ratio: 3)">

<!-- SEO & Sharing -->
<meta name="description" content="Havacılık çalışanlarının dünya rehberi. Ekip arkadaşlarının tavsiyelerini keşfet.">
<meta name="application-name" content="CrewGuide">
<meta property="og:title" content="CrewGuide">
<meta property="og:description" content="Havacılık çalışanlarının dünya rehberi">
<meta property="og:type" content="website">

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<!-- Leaflet.js — OpenStreetMap -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  :root {
    --navy: #0f1729;
    --navy-light: #1a2640;
    --navy-mid: #243354;
    --gold: #c9a84c;
    --gold-light: #e8c96a;
    --cream: #f5f0e8;
    --cream-dark: #ede7d9;
    --white: #ffffff;
    --text-primary: #0f1729;
    --text-secondary: #6b7280;
    --text-muted: #9ca3af;
    --success: #10b981;
    --danger: #ef4444;
    --border: rgba(15,23,41,0.1);
    --shadow: 0 4px 24px rgba(15,23,41,0.08);
    --radius: 16px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #e8e4dc;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 0;
  }

  #app {
    width: 100%;
    max-width: 430px;
    min-height: 100vh;
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  /* SCREENS */
  .screen {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    background: var(--cream);
    transition: opacity 0.25s ease;
  }
  .screen.active { display: flex; }

  /* TYPOGRAPHY */
  .font-display { font-family: 'Syne', sans-serif; }

  /* STATUS BAR */
  .status-bar {
    background: var(--navy);
    height: 44px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 20px 8px;
    flex-shrink: 0;
  }
  .status-time { color: rgba(255,255,255,0.9); font-size: 12px; font-weight: 500; }
  .status-icons { display: flex; gap: 5px; align-items: center; }
  .status-icon { width: 14px; height: 10px; background: rgba(255,255,255,0.7); border-radius: 2px; }
  .status-icon.signal { width: 12px; clip-path: polygon(0 100%, 33% 60%, 66% 30%, 100% 0, 100% 100%); }
  .status-icon.battery { width: 18px; height: 9px; border: 1.5px solid rgba(255,255,255,0.7); border-radius: 2px; position: relative; }
  .status-icon.battery::after { content:''; position:absolute; right:-4px; top:2px; width:3px; height:5px; background:rgba(255,255,255,0.7); border-radius:0 1px 1px 0; }
  .status-icon.battery::before { content:''; position:absolute; inset:1px 3px 1px 1px; background:rgba(255,255,255,0.7); border-radius:1px; }

  /* SPLASH SCREEN */
  #screen-splash {
    background: var(--navy);
    justify-content: space-between;
    padding-bottom: 0;
  }
  .splash-top { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 32px; }
  .splash-logo {
    width: 80px; height: 80px;
    background: rgba(201,168,76,0.15);
    border: 1.5px solid rgba(201,168,76,0.3);
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    font-size: 36px;
    margin-bottom: 24px;
  }
  .splash-title { font-family: 'Syne', sans-serif; font-size: 36px; font-weight: 700; color: var(--white); letter-spacing: -1px; }
  .splash-tagline { font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 8px; text-align: center; line-height: 1.6; letter-spacing: 0.3px; }
  .splash-lang { display: flex; gap: 8px; margin-top: 24px; }
  .lang-btn { padding: 6px 16px; border-radius: 20px; font-size: 11px; font-weight: 500; cursor: pointer; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); background: transparent; transition: all 0.2s; }
  .lang-btn.active { background: var(--gold); border-color: var(--gold); color: var(--navy); }
  .splash-bottom { padding: 32px; display: flex; flex-direction: column; gap: 10px; }
  .btn-primary {
    width: 100%; padding: 16px; border-radius: var(--radius);
    background: var(--gold); color: var(--navy);
    font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 600;
    border: none; cursor: pointer; transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .btn-primary:active { transform: scale(0.98); opacity: 0.9; }
  .btn-outline {
    width: 100%; padding: 15px; border-radius: var(--radius);
    background: transparent; color: rgba(255,255,255,0.7);
    font-size: 14px; font-weight: 500;
    border: 1px solid rgba(255,255,255,0.2); cursor: pointer; transition: all 0.2s;
  }
  .btn-outline:active { opacity: 0.7; }
  .splash-note { text-align: center; font-size: 10px; color: rgba(255,255,255,0.25); line-height: 1.6; padding: 0 0 16px; }

  /* INVITE SCREEN */
  .navy-header {
    background: var(--navy);
    padding: 16px 20px 20px;
    flex-shrink: 0;
  }
  .nav-back { color: rgba(255,255,255,0.6); font-size: 13px; cursor: pointer; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .nav-back::before { content: '←'; }
  .header-title { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: var(--white); }
  .header-sub { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 4px; }
  .step-indicator { display: flex; gap: 5px; margin-top: 14px; }
  .step-dot { height: 3px; border-radius: 2px; background: rgba(255,255,255,0.2); flex: 1; }
  .step-dot.active { background: var(--gold); }

  .screen-body { flex: 1; padding: 24px 20px; display: flex; flex-direction: column; gap: 20px; }

  .invite-visual { text-align: center; padding: 12px 0; }
  .invite-icon-big { font-size: 48px; margin-bottom: 12px; }
  .invite-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }

  .code-entry { display: flex; flex-direction: column; gap: 8px; }
  .field-label { font-size: 11px; font-weight: 500; color: var(--text-secondary); letter-spacing: 0.5px; text-transform: uppercase; }
  .code-boxes { display: flex; gap: 8px; }
  .code-box {
    flex: 1; height: 52px;
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700;
    color: var(--text-primary); transition: all 0.2s;
  }
  .code-box.filled { border-color: var(--navy); background: #f0f3f9; }
  .code-hint { font-size: 11px; color: var(--text-muted); text-align: center; }

  .btn-navy {
    width: 100%; padding: 16px; border-radius: var(--radius);
    background: var(--navy); color: var(--white);
    font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 600;
    border: none; cursor: pointer; transition: all 0.2s;
  }
  .btn-navy:active { transform: scale(0.98); opacity: 0.9; }
  .btn-ghost { background: none; border: none; font-size: 12px; color: var(--text-muted); cursor: pointer; padding: 8px; text-align: center; }

  /* PROFILE SETUP */
  .avatar-picker { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 8px 0; }
  .avatar-circle {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--navy-light); border: 2px dashed rgba(201,168,76,0.4);
    display: flex; align-items: center; justify-content: center; font-size: 28px; cursor: pointer;
  }
  .avatar-hint { font-size: 11px; color: var(--text-muted); }

  .field-group { display: flex; flex-direction: column; gap: 6px; }
  .field-input {
    width: 100%; padding: 14px 16px;
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius-sm); font-size: 14px; color: var(--text-primary);
    font-family: 'DM Sans', sans-serif; outline: none; transition: border 0.2s;
  }
  .field-input:focus { border-color: var(--navy); }
  .field-input::placeholder { color: var(--text-muted); }

  .privacy-box {
    background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: var(--radius-sm); padding: 12px 14px;
    display: flex; gap: 10px; align-items: flex-start;
  }
  .privacy-box-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }
  .privacy-box-text { font-size: 11px; color: #166534; line-height: 1.6; }

  /* WELCOME SCREEN */
  #screen-welcome { background: var(--navy); }
  .welcome-body { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px; text-align: center; }
  .welcome-emoji { font-size: 56px; margin-bottom: 20px; }
  .welcome-title { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
  .welcome-sub { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.7; margin-bottom: 28px; }
  .invite-code-display {
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3);
    border-radius: var(--radius); padding: 20px; width: 100%; margin-bottom: 28px;
  }
  .invite-code-label { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
  .invite-code-value { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 700; color: var(--gold); letter-spacing: 4px; }
  .invite-code-quota { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 6px; }

  /* HOME SCREEN */
  .home-header { background: var(--navy); padding: 16px 20px 0; flex-shrink: 0; }
  .home-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .home-logo { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; color: var(--white); }
  .home-avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(201,168,76,0.2); border: 1.5px solid rgba(201,168,76,0.4); display: flex; align-items: center; justify-content: center; font-size: 14px; cursor: pointer; }
  .location-pill {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px; padding: 5px 12px; font-size: 12px; color: rgba(255,255,255,0.8);
    margin-bottom: 14px; cursor: pointer;
  }
  .location-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); }
  .search-bar {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-sm); padding: 10px 14px; margin-bottom: 16px; cursor: pointer;
  }
  .search-icon { font-size: 14px; }
  .search-placeholder { font-size: 13px; color: rgba(255,255,255,0.4); }
  #search-input::placeholder { color: rgba(255,255,255,0.4); }
  #search-input { caret-color: rgba(255,255,255,0.8); }

  .cat-tabs { display: flex; gap: 8px; padding-bottom: 1px; overflow-x: auto; scrollbar-width: none; }
  .cat-tabs::-webkit-scrollbar { display: none; }
  .cat-tab {
    flex-shrink: 0; padding: 8px 16px;
    border-radius: 20px 20px 0 0; font-size: 12px; font-weight: 500;
    cursor: pointer; border: none; transition: all 0.2s;
    color: rgba(255,255,255,0.5); background: transparent;
  }
  .cat-tab.active { background: var(--cream); color: var(--navy); font-weight: 600; }

  .home-content { flex: 1; padding: 16px 20px; display: flex; flex-direction: column; gap: 12px; }

  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 600; color: var(--text-primary); }
  .section-more { font-size: 12px; color: var(--gold); cursor: pointer; }

  .place-card {
    background: var(--white); border-radius: var(--radius);
    border: 1px solid var(--border); overflow: hidden;
    box-shadow: var(--shadow); cursor: pointer; transition: transform 0.2s;
  }
  .place-card:active { transform: scale(0.99); }
  .place-card-img {
    height: 130px; display: flex; align-items: center; justify-content: center;
    font-size: 40px; position: relative;
  }
  .place-card-img.food { background: linear-gradient(135deg, #fef3c7, #fde68a); }
  .place-card-img.shopping { background: linear-gradient(135deg, #e0e7ff, #c7d2fe); }
  .place-card-img.sightseeing { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
  .card-badge {
    position: absolute; top: 10px; left: 10px;
    background: var(--navy); color: var(--white);
    font-size: 9px; font-weight: 600; padding: 3px 8px; border-radius: 10px;
    letter-spacing: 0.5px;
  }
  .place-card-body { padding: 12px 14px; }
  .place-card-name { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; }
  .place-card-meta { font-size: 11px; color: var(--text-muted); margin-bottom: 8px; }
  .place-card-row { display: flex; align-items: center; justify-content: space-between; }
  .price-tag { font-size: 11px; font-weight: 500; color: var(--navy); background: #f0f3f9; padding: 3px 8px; border-radius: 6px; }
  .likes-tag { font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; }
  .heart { color: #f87171; }

  /* BOTTOM NAV */
  .bottom-nav {
    background: var(--white); border-top: 1px solid var(--border);
    display: flex; padding: 8px 0 20px; flex-shrink: 0;
    position: sticky; bottom: 0;
  }
  .bnav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; padding: 4px 0; }
  .bnav-icon { font-size: 20px; }
  .bnav-label { font-size: 9px; color: var(--text-muted); font-weight: 500; }
  .bnav-item.active .bnav-label { color: var(--navy); font-weight: 600; }
  .bnav-add { width: 48px; height: 48px; border-radius: 50%; background: var(--navy); display: flex; align-items: center; justify-content: center; font-size: 22px; color: var(--white); margin-top: -20px; box-shadow: 0 4px 16px rgba(15,23,41,0.3); }

  /* DETAIL SCREEN */
  .detail-hero { height: 200px; display: flex; align-items: center; justify-content: center; font-size: 64px; position: relative; flex-shrink: 0; }
  .detail-hero.food { background: linear-gradient(135deg, #fef3c7, #fde68a); }
  .detail-hero.shopping { background: linear-gradient(135deg, #e0e7ff, #c7d2fe); }
  .detail-hero.sightseeing { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
  .detail-back { position: absolute; top: 16px; left: 16px; width: 36px; height: 36px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; }
  .detail-save { position: absolute; top: 16px; right: 16px; width: 36px; height: 36px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; }
  .detail-body { flex: 1; padding: 20px; }
  .detail-name { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
  .detail-addr { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; display: flex; align-items: center; gap: 4px; }
  .detail-badges { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
  .badge { font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 8px; }
  .badge-cat { background: #f0f3f9; color: var(--navy); }
  .badge-price { background: #fef3c7; color: #92400e; }
  .badge-sub { background: var(--cream-dark); color: var(--text-secondary); }
  .map-placeholder { width: 100%; height: 80px; background: #e8f4f0; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 13px; color: #2d6a4f; margin-bottom: 16px; gap: 6px; border: 1px solid #b7e4c7; cursor: pointer; }
  .detail-section { margin-bottom: 16px; }
  .detail-section-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
  .detail-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.7; }
  .review-card { background: var(--cream-dark); border-radius: var(--radius-sm); padding: 12px; margin-bottom: 8px; }
  .review-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
  .review-user { font-size: 12px; font-weight: 600; color: var(--text-primary); }
  .review-stars { font-size: 11px; color: #f59e0b; letter-spacing: 1px; }
  .review-text { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }
  .detail-actions { display: flex; gap: 8px; margin-top: 8px; padding-bottom: 24px; }
  .action-btn { flex: 1; padding: 12px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 500; border: 1.5px solid var(--border); background: var(--white); color: var(--text-secondary); cursor: pointer; text-align: center; transition: all 0.2s; }
  .action-btn:active { background: var(--cream-dark); }
  .action-btn.primary { background: var(--navy); color: var(--white); border-color: var(--navy); font-family: 'Syne', sans-serif; }

  /* STAR RATING */
  .star-rating-bar {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 14px 16px;
    margin-bottom: 16px; display: flex; flex-direction: column; gap: 10px;
  }
  .star-rating-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-primary); }
  .star-rating-summary { display: flex; align-items: center; gap: 12px; }
  .star-big-num { font-family: 'Syne', sans-serif; font-size: 36px; font-weight: 700; color: var(--text-primary); line-height: 1; }
  .star-big-right { display: flex; flex-direction: column; gap: 4px; }
  .stars-display { display: flex; gap: 2px; }
  .stars-display span { font-size: 18px; }
  .star-count-text { font-size: 11px; color: var(--text-muted); }
  .star-bars { display: flex; flex-direction: column; gap: 4px; margin-top: 4px; }
  .star-bar-row { display: flex; align-items: center; gap: 6px; }
  .star-bar-label { font-size: 10px; color: var(--text-muted); width: 10px; text-align: right; flex-shrink: 0; }
  .star-bar-track { flex: 1; height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; }
  .star-bar-fill { height: 100%; background: #f59e0b; border-radius: 3px; transition: width 0.4s ease; }
  .star-bar-num { font-size: 10px; color: var(--text-muted); width: 16px; flex-shrink: 0; }
  .star-input-row { display: flex; align-items: center; gap: 8px; padding-top: 10px; border-top: 1px solid var(--border); }
  .star-input-label { font-size: 12px; color: var(--text-secondary); flex-shrink: 0; }
  .star-input { display: flex; gap: 4px; }
  .star-input span { font-size: 24px; cursor: pointer; transition: transform 0.15s; filter: grayscale(1) opacity(0.4); }
  .star-input span:hover, .star-input span.active { filter: none; transform: scale(1.2); }
  .star-input span.lit { filter: none; }
  .star-submit-btn { margin-left: auto; padding: 6px 14px; border-radius: 8px; background: var(--navy); color: var(--white); font-size: 11px; font-family: 'Syne', sans-serif; font-weight: 600; border: none; cursor: pointer; transition: opacity 0.2s; }
  .star-submit-btn:active { opacity: 0.8; }
  .card-stars { font-size: 10px; color: #f59e0b; letter-spacing: 0.5px; }
  .card-rating-num { font-size: 10px; font-weight: 600; color: var(--text-primary); margin-left: 2px; }

  /* DİL DROPDOWN */
  .lang-dropdown-wrapper { position: relative; margin-top: 20px; }
  .lang-dropdown-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 18px; border-radius: 20px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.85); font-size: 13px; font-weight: 500;
    cursor: pointer; transition: all 0.2s;
  }
  .lang-dropdown-btn:hover { background: rgba(255,255,255,0.15); }
  .lang-dropdown-btn .arrow { font-size: 10px; transition: transform 0.2s; }
  .lang-dropdown-btn.open .arrow { transform: rotate(180deg); }
  .lang-dropdown-menu {
    position: absolute; top: calc(100% + 6px); left: 50%;
    transform: translateX(-50%);
    background: var(--navy-light); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px; padding: 6px; min-width: 180px;
    display: none; flex-direction: column; gap: 2px;
    z-index: 50; box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .lang-dropdown-menu.open { display: flex; }
  .lang-option {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 14px; border-radius: 10px;
    font-size: 13px; color: rgba(255,255,255,0.75);
    cursor: pointer; transition: background 0.15s; border: none;
    background: transparent; width: 100%; text-align: left;
  }
  .lang-option:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .lang-option.active { background: var(--gold); color: var(--navy); font-weight: 600; }
  .lang-option .lang-flag { font-size: 18px; flex-shrink: 0; }
  .lang-option .lang-name { flex: 1; }


  .lang-setting-btn {
    padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;
    border: 1.5px solid var(--border); background: var(--white);
    color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
  }
  .lang-setting-btn.active {
    background: var(--navy); color: #fff; border-color: var(--navy);
  }


  /* +18 TOGGLE & ADMIN */
  .adult-toggle-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; background: #fff7ed;
    border: 1.5px solid #fed7aa; border-radius: var(--radius-sm);
  }
  .adult-toggle-left { display: flex; align-items: center; gap: 8px; }
  .adult-toggle-icon { font-size: 18px; }
  .adult-toggle-label { font-size: 13px; font-weight: 500; color: #c2410c; }
  .adult-toggle-sub { font-size: 11px; color: #ea580c; margin-top: 1px; }

  /* Admin badge */
  .admin-badge {
    display: inline-flex; align-items: center; gap: 4px;
    background: #fef2f2; border: 1px solid #fca5a5;
    border-radius: 6px; padding: 2px 8px;
    font-size: 10px; font-weight: 600; color: #ef4444;
  }

  /* +18 kart badge */
  .card-adult-badge {
    position: absolute; top: 10px; right: 10px;
    background: #ef4444; color: #fff;
    font-size: 9px; font-weight: 700; padding: 3px 7px;
    border-radius: 8px; letter-spacing: 0.5px;
  }

  /* +18 filtre toggle ana ekranda */
  .adult-filter-row {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 20px; background: var(--cream); flex-shrink: 0;
  }
  .adult-filter-label { font-size: 11px; color: var(--text-muted); flex: 1; }


  /* YORUM DÜZENLE / SİL */
  .comment-actions {
    display: flex; gap: 6px; margin-top: 8px;
  }
  .comment-action-btn {
    padding: 4px 10px; border-radius: 6px; font-size: 11px;
    font-weight: 500; cursor: pointer; border: 1px solid var(--border);
    background: var(--white); color: var(--text-muted);
    transition: all 0.15s; font-family: 'DM Sans', sans-serif;
  }
  .comment-action-btn:hover { background: var(--cream-dark); }
  .comment-action-btn.edit { color: var(--navy); border-color: var(--navy); }
  .comment-action-btn.delete { color: #ef4444; border-color: #fca5a5; }

  /* Düzenleme textarea inline */
  .comment-edit-area {
    width: 100%; margin-top: 8px; padding: 8px 10px;
    background: var(--white); border: 1.5px solid var(--navy);
    border-radius: var(--radius-sm); font-size: 12px;
    font-family: 'DM Sans', sans-serif; resize: none; height: 64px;
    color: var(--text-primary); outline: none;
  }
  .comment-edit-actions { display: flex; gap: 6px; margin-top: 6px; }
  .comment-edit-save {
    flex: 1; padding: 7px; border-radius: 8px;
    background: var(--navy); color: #fff;
    font-size: 12px; font-family: 'Syne', sans-serif; font-weight: 600;
    border: none; cursor: pointer;
  }
  .comment-edit-cancel {
    flex: 1; padding: 7px; border-radius: 8px;
    background: transparent; color: var(--text-muted);
    font-size: 12px; border: 1px solid var(--border); cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }


  /* GELİŞMİŞ FİLTRELER */
  .filter-bar {
    display: flex; gap: 6px; padding: 10px 20px 8px;
    overflow-x: auto; scrollbar-width: none; flex-shrink: 0;
    background: var(--cream);
  }
  .filter-bar::-webkit-scrollbar { display: none; }
  .filter-chip {
    flex-shrink: 0; display: flex; align-items: center; gap: 4px;
    padding: 5px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 500; cursor: pointer;
    border: 1.5px solid var(--border);
    color: var(--text-secondary); background: var(--white);
    transition: all 0.2s; white-space: nowrap;
  }
  .filter-chip.active {
    background: var(--cream-dark);
    border-color: var(--navy);
    color: var(--navy);
  }
  .filter-chip.has-value {
    background: var(--gold); border-color: var(--gold); color: var(--navy);
    font-weight: 600;
  }
  .filter-panel {
    background: var(--white); border-radius: var(--radius) var(--radius) 0 0;
    padding: 20px; position: absolute; bottom: 0; left: 0; right: 0;
    z-index: 90; box-shadow: 0 -4px 24px rgba(0,0,0,0.12);
    display: none; flex-direction: column; gap: 16px;
    max-height: 70vh; overflow-y: auto;
  }
  .filter-panel.open { display: flex; }
  .filter-panel-handle { width: 36px; height: 4px; background: var(--border); border-radius: 2px; margin: 0 auto -8px; }
  .filter-panel-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text-primary); }
  .filter-section-label { font-size: 11px; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 6px; }
  .filter-option-grid { display: flex; flex-wrap: wrap; gap: 6px; }
  .filter-opt-btn {
    padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 500;
    border: 1.5px solid var(--border); background: var(--white);
    color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
  }
  .filter-opt-btn.selected { border-color: var(--navy); background: var(--navy); color: #fff; }
  .filter-rating-row { display: flex; gap: 6px; }
  .filter-rating-btn {
    flex: 1; padding: 8px; border-radius: 10px; text-align: center;
    border: 1.5px solid var(--border); background: var(--white);
    font-size: 13px; cursor: pointer; transition: all 0.15s;
  }
  .filter-rating-btn.selected { border-color: #f59e0b; background: #fef9ec; }
  .filter-actions { display: flex; gap: 8px; padding-top: 4px; }
  .filter-clear-btn {
    flex: 1; padding: 11px; border-radius: var(--radius-sm);
    border: 1.5px solid var(--border); background: transparent;
    font-size: 13px; color: var(--text-muted); cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }
  .filter-apply-btn {
    flex: 2; padding: 11px; border-radius: var(--radius-sm);
    background: var(--navy); color: #fff;
    font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600;
    border: none; cursor: pointer;
  }
  .filter-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.4);
    z-index: 89; display: none;
  }
  .filter-overlay.open { display: block; }

  /* Kart layout - liste görünümü */
  .home-content.list-view .place-card { display: flex; }
  .home-content.list-view .place-card-img { width: 90px; height: 90px; flex-shrink: 0; }
  .home-content.list-view .place-card-body { flex: 1; }

  /* Sonuç sayısı */
  .results-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 4px 20px 0; flex-shrink: 0;
    background: var(--cream);
  }
  .results-count { font-size: 11px; color: var(--text-muted); }
  .sort-btn {
    font-size: 11px; color: rgba(255,255,255,0.6); background: none;
    border: none; cursor: pointer; display: flex; align-items: center; gap: 4px;
  }


  /* MAP */
  .map-placeholder {
    width: 100%; height: 80px; background: #e8f4f0;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; color: #2d6a4f; margin-bottom: 16px; gap: 6px;
    border: 1px solid #b7e4c7; cursor: pointer; transition: all 0.2s;
  }
  .map-placeholder:hover { background: #d1f0e8; }
  .map-placeholder.loading { color: #f59e0b; border-color: #fde68a; background: #fef9ec; }

  /* Harita modal */
  .map-modal {
    position: absolute; inset: 0; background: var(--cream);
    z-index: 180; display: flex; flex-direction: column;
  }
  .map-modal-header {
    background: var(--navy); padding: 14px 16px;
    display: flex; align-items: center; gap: 12px; flex-shrink: 0;
  }
  .map-close-btn {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.12); border: none;
    color: #fff; font-size: 16px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .map-modal-title {
    font-family: 'Syne', sans-serif; font-size: 15px;
    font-weight: 600; color: #fff; flex: 1;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .map-modal-addr {
    font-size: 11px; color: rgba(255,255,255,0.5); margin-top: 1px;
  }
  #map-container {
    flex: 1; min-height: 0;
  }
  .map-actions-bar {
    background: var(--white); border-top: 1px solid var(--border);
    padding: 12px 16px 24px; display: flex; gap: 8px; flex-shrink: 0;
  }
  .map-action-btn {
    flex: 1; padding: 11px; border-radius: var(--radius-sm);
    font-size: 12px; font-weight: 500; border: 1.5px solid var(--border);
    background: var(--white); color: var(--text-secondary);
    cursor: pointer; text-align: center; transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .map-action-btn.primary {
    background: var(--navy); color: #fff;
    border-color: var(--navy); font-family: 'Syne', sans-serif; font-weight: 600;
  }
  .map-action-btn:active { opacity: 0.8; }


  /* PHOTO UPLOAD & GALLERY */
  .photo-upload-area {
    border: 2px dashed var(--border); border-radius: var(--radius-sm);
    padding: 20px; text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
  }
  .photo-upload-area:hover { border-color: var(--navy); background: #f8f9fb; }
  .photo-upload-area.drag-over { border-color: var(--gold); background: #fef9ec; }
  .photo-preview-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-top: 10px;
  }
  .photo-preview-item {
    position: relative; aspect-ratio: 1; border-radius: 8px; overflow: hidden;
    background: var(--border);
  }
  .photo-preview-item img { width: 100%; height: 100%; object-fit: cover; }
  .photo-preview-remove {
    position: absolute; top: 3px; right: 3px;
    width: 18px; height: 18px; border-radius: 50%;
    background: rgba(0,0,0,0.6); color: #fff;
    font-size: 10px; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .photo-progress {
    height: 3px; background: var(--border); border-radius: 2px;
    margin-top: 8px; overflow: hidden; display: none;
  }
  .photo-progress-fill {
    height: 100%; background: var(--gold); border-radius: 2px;
    width: 0%; transition: width 0.3s ease;
  }

  /* DETAIL PHOTO GALLERY */
  .detail-gallery {
    display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px;
    margin-bottom: 16px; scrollbar-width: none;
  }
  .detail-gallery::-webkit-scrollbar { display: none; }
  .detail-gallery-item {
    flex-shrink: 0; width: 120px; height: 90px;
    border-radius: 10px; overflow: hidden; cursor: pointer;
    background: var(--border);
  }
  .detail-gallery-item img { width: 100%; height: 100%; object-fit: cover; }
  .detail-gallery-item:first-child { width: 200px; }

  /* Lightbox */
  .lightbox {
    position: absolute; inset: 0; background: rgba(0,0,0,0.92);
    z-index: 200; display: flex; align-items: center; justify-content: center;
    flex-direction: column;
  }
  .lightbox img { max-width: 100%; max-height: 80vh; border-radius: 8px; object-fit: contain; }
  .lightbox-close {
    position: absolute; top: 16px; right: 16px;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,0.15); color: #fff;
    font-size: 18px; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .lightbox-counter {
    color: rgba(255,255,255,0.6); font-size: 12px; margin-top: 12px;
  }


  /* COMMENT SYSTEM */
  .comments-list { display:flex; flex-direction:column; gap:8px; }
  .comment-card { background:var(--cream-dark); border-radius:var(--radius-sm); padding:12px; }
  .comment-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
  .comment-user { font-size:12px; font-weight:600; color:var(--text-primary); }
  .comment-meta { display:flex; align-items:center; gap:6px; }
  .comment-stars { font-size:11px; color:#f59e0b; }
  .comment-date { font-size:10px; color:var(--text-muted); }
  .comment-text { font-size:12px; color:var(--text-secondary); line-height:1.5; }
  .comment-empty { text-align:center; padding:20px; color:var(--text-muted); font-size:13px; }
  .comment-loading { text-align:center; padding:16px; color:var(--text-muted); font-size:12px; }

  /* COMMENT INPUT */
  .comment-input-box {
    background:var(--white); border:1.5px solid var(--border);
    border-radius:var(--radius); padding:14px; margin-top:8px;
    display:flex; flex-direction:column; gap:10px;
  }
  .comment-input-header { font-family:'Syne',sans-serif; font-size:13px; font-weight:600; color:var(--text-primary); }
  .comment-name-row { display:flex; gap:8px; align-items:center; }
  .comment-name-input {
    flex:1; padding:9px 12px; background:var(--cream);
    border:1.5px solid var(--border); border-radius:var(--radius-sm);
    font-size:13px; font-family:'DM Sans',sans-serif; outline:none; color:var(--text-primary);
  }
  .comment-name-input:focus { border-color:var(--navy); }
  .comment-star-pick { display:flex; gap:3px; }
  .comment-star-pick span { font-size:20px; cursor:pointer; filter:grayscale(1) opacity(0.4); transition:all 0.15s; }
  .comment-star-pick span.lit { filter:none; color:#f59e0b; }
  .comment-textarea {
    width:100%; padding:10px 12px; background:var(--cream);
    border:1.5px solid var(--border); border-radius:var(--radius-sm);
    font-size:13px; font-family:'DM Sans',sans-serif; outline:none;
    resize:none; height:72px; color:var(--text-primary); transition:border 0.2s;
  }
  .comment-textarea:focus { border-color:var(--navy); }
  .comment-submit-btn {
    width:100%; padding:12px; border-radius:var(--radius-sm);
    background:var(--navy); color:var(--white);
    font-family:'Syne',sans-serif; font-size:14px; font-weight:600;
    border:none; cursor:pointer; transition:opacity 0.2s;
    display:flex; align-items:center; justify-content:center; gap:6px;
  }
  .comment-submit-btn:active { opacity:0.85; }
  .comment-submit-btn.loading { opacity:0.6; pointer-events:none; }



  /* ADD SCREEN */
  .add-body { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 16px; }
  .main-cat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  .main-cat-btn {
    padding: 14px 8px; border-radius: var(--radius-sm); text-align: center;
    border: 1.5px solid var(--border); background: var(--white);
    font-size: 11px; font-weight: 500; color: var(--text-secondary); cursor: pointer; transition: all 0.2s;
  }
  .main-cat-btn .cat-emoji { font-size: 22px; display: block; margin-bottom: 4px; }
  .main-cat-btn.selected { border-color: var(--navy); background: #f0f3f9; color: var(--navy); font-weight: 600; }
  .sub-cat-wrap { display: flex; flex-wrap: wrap; gap: 6px; }
  .sub-cat-btn {
    padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 500;
    border: 1.5px solid var(--border); background: var(--white); color: var(--text-secondary); cursor: pointer; transition: all 0.2s;
  }
  .sub-cat-btn.selected { border-color: var(--navy); background: var(--navy); color: var(--white); }
  .price-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  .price-opt { padding: 12px; border-radius: var(--radius-sm); text-align: center; border: 1.5px solid var(--border); background: var(--white); cursor: pointer; transition: all 0.2s; }
  .price-opt .price-sym { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; color: var(--text-primary); display: block; }
  .price-opt .price-name { font-size: 9px; color: var(--text-muted); margin-top: 2px; }
  .price-opt.selected { border-color: var(--gold); background: #fef9ec; }
  .photo-upload { border: 2px dashed var(--border); border-radius: var(--radius-sm); padding: 24px; text-align: center; cursor: pointer; }
  .photo-upload-icon { font-size: 28px; margin-bottom: 6px; }
  .photo-upload-text { font-size: 12px; color: var(--text-muted); }
  .photo-upload-opt { font-size: 10px; color: var(--text-muted); margin-top: 3px; }
  .field-textarea { width: 100%; padding: 12px 14px; background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-size: 13px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; outline: none; resize: none; height: 80px; transition: border 0.2s; }
  .field-textarea:focus { border-color: var(--navy); }
  .field-textarea::placeholder { color: var(--text-muted); }

  /* PROFILE SCREEN */
  .profile-hero-section { background: var(--navy); padding: 20px; text-align: center; }
  .profile-avatar { width: 64px; height: 64px; border-radius: 50%; background: rgba(201,168,76,0.2); border: 2px solid rgba(201,168,76,0.4); display: flex; align-items: center; justify-content: center; font-size: 26px; margin: 0 auto 10px; }
  .profile-name { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; color: var(--white); }
  .profile-since { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 3px; }
  .profile-stats { display: flex; justify-content: center; gap: 28px; margin-top: 16px; }
  .p-stat { text-align: center; }
  .p-stat-num { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; color: var(--white); }
  .p-stat-label { font-size: 9px; color: rgba(255,255,255,0.4); margin-top: 2px; }
  .profile-body { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 20px; }
  .profile-section { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; }
  .profile-section-header { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .profile-section-title { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-primary); }
  .invite-display { padding: 16px; }
  .invite-code-big { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .invite-code-text { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: 3px; color: var(--navy); }
  .copy-btn-small { font-size: 11px; background: var(--navy); color: var(--white); border: none; border-radius: 6px; padding: 5px 12px; cursor: pointer; font-family: 'DM Sans', sans-serif; }
  .quota-text { font-size: 11px; color: var(--text-muted); margin-bottom: 6px; }
  .quota-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .quota-fill { height: 100%; background: var(--gold); border-radius: 2px; width: 33%; }
  .place-row-profile { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-bottom: 1px solid var(--border); cursor: pointer; }
  .place-row-profile:last-child { border-bottom: none; }
  .place-icon-profile { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
  .place-row-info { flex: 1; }
  .place-row-name { font-size: 13px; font-weight: 500; color: var(--text-primary); }
  .place-row-meta { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .place-row-likes { font-size: 12px; color: var(--text-muted); }
  .city-row-profile { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-bottom: 1px solid var(--border); }
  .city-row-profile:last-child { border-bottom: none; }
  .city-flag-big { font-size: 22px; }
  .city-info { flex: 1; }
  .city-name-text { font-size: 13px; font-weight: 500; color: var(--text-primary); }
  .city-meta-text { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .city-right-profile { display: flex; align-items: center; gap: 8px; }
  .city-size-text { font-size: 10px; color: var(--text-muted); }
  .city-delete { background: none; border: none; color: #fca5a5; font-size: 14px; cursor: pointer; }

  /* DOWNLOAD MODAL */
  .modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); z-index: 100; display: none; align-items: flex-end; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal-sheet { background: var(--cream); border-radius: 24px 24px 0 0; padding: 20px; width: 100%; }
  .sheet-handle { width: 36px; height: 4px; background: var(--border); border-radius: 2px; margin: 0 auto 16px; }
  .modal-title { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
  .modal-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.5; }
  .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .toggle-row:last-of-type { border-bottom: none; }
  .toggle-label { font-size: 13px; color: var(--text-primary); }
  .toggle-sublabel { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .toggle { width: 40px; height: 22px; border-radius: 11px; position: relative; cursor: pointer; flex-shrink: 0; transition: background 0.2s; }
  .toggle.on { background: var(--navy); }
  .toggle.off { background: #d1d5db; }
  .toggle-knob { width: 18px; height: 18px; background: var(--white); border-radius: 50%; position: absolute; top: 2px; transition: left 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  .toggle.on .toggle-knob { left: 20px; }
  .toggle.off .toggle-knob { left: 2px; }
  .modal-size { font-size: 12px; color: var(--text-muted); text-align: center; margin-top: 10px; }

  /* SUCCESS TOAST */
  .toast {
    position: fixed; top: 60px; left: 50%; transform: translateX(-50%) translateY(-100px);
    background: var(--navy); color: var(--white);
    padding: 10px 20px; border-radius: 20px; font-size: 13px; font-weight: 500;
    z-index: 200; transition: transform 0.3s ease; white-space: nowrap;
    max-width: 300px;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* UTILS */
  .divider { height: 1px; background: var(--border); }
  .spacer { flex: 1; }
  .hidden { display: none !important; }
  .text-center { text-align: center; }
  .mt-8 { margin-top: 8px; }
</style>
</head>
<body>
<div id="app">

  <!-- TOAST -->
  <div class="toast" id="toast"></div>

  <!-- DOWNLOAD MODAL -->
  <div class="modal-overlay" id="downloadModal">
    <div class="modal-sheet">
      <div class="sheet-handle"></div>
      <div class="modal-title" id="downloadCityName">Seoul İndir</div>
      <div class="modal-sub" id="downloadCitySub">İnternetsiz kaldığında bu şehrin verilerine ulaşabilirsin.</div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label" id="dl-t1">Yer bilgileri & adresler</div>
          <div class="toggle-sublabel" id="dl-s1">Her zaman dahil · ~2.1 MB</div>
        </div>
        <div class="toggle on"><div class="toggle-knob"></div></div>
      </div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label" id="dl-t2">Fotoğraflar</div>
          <div class="toggle-sublabel" id="dl-s2">Opsiyonel · ~16 MB ekstra</div>
        </div>
        <div class="toggle off" id="togglePhotos" onclick="toggleDownloadOption(this)"><div class="toggle-knob"></div></div>
      </div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label" id="dl-t3">Yorumlar</div>
          <div class="toggle-sublabel" id="dl-s3">Opsiyonel · ~0.4 MB ekstra</div>
        </div>
        <div class="toggle on" id="toggleReviews" onclick="toggleDownloadOption(this)"><div class="toggle-knob"></div></div>
      </div>
      <button class="btn-navy mt-8" onclick="confirmDownload()" id="downloadBtn">⬇ İndir</button>
      <div class="modal-size" id="downloadSize">Toplam: ~2.5 MB indirilecek</div>
      <button class="btn-ghost" onclick="closeModal()" style="width:100%;margin-top:6px;" id="dl-cancel">İptal</button>
    </div>
  </div>

  <!-- SCREEN: CITY SELECT -->
  <div class="screen" id="screen-city">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header">
      <div class="nav-back" onclick="goTo('screen-home')" id="back-city">← </div>
      <div class="header-title font-display" id="city-modal-title">Şehir Seç</div>
      <div class="header-sub" id="city-modal-sub">Mevcut konumun veya başka bir şehir ara</div>
    </div>
    <div style="padding:12px 16px;flex:1;display:flex;flex-direction:column;gap:8px;overflow:hidden;">
      <div style="position:relative;flex-shrink:0;">
        <input type="text" id="city-search-input" autocomplete="off"
          style="width:100%;padding:12px 44px 12px 14px;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;"
          oninput="filterCities(this.value)"
          placeholder="Şehir ara..."
        >
        <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:16px;">🔍</span>
      </div>
      <div id="city-list" style="display:flex;flex-direction:column;gap:2px;overflow-y:auto;flex:1;padding-bottom:20px;"></div>
    </div>
  </div>


  <!-- SCREEN: LOGIN -->
  <div class="screen" id="screen-login">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header">
      <div class="nav-back" onclick="goTo('screen-splash')">← </div>
      <div class="header-title font-display" id="login-title">Giriş Yap</div>
      <div class="header-sub" id="login-sub">CrewGuide hesabına giriş yap</div>
    </div>
    <div class="screen-body">
      <div class="invite-visual">
        <div class="invite-icon-big">✈️</div>
      </div>
      <div class="field-group">
        <div class="field-label" id="label-login-email">E-POSTA</div>
        <input class="field-input" type="email" id="login-email" placeholder="email@gmail.com" autocomplete="email">
      </div>
      <div class="field-group">
        <div class="field-label" id="label-login-pass">ŞİFRE</div>
        <input class="field-input" type="password" id="login-password" placeholder="••••••••" autocomplete="current-password">
      </div>
      <button class="btn-navy" onclick="signIn()" id="btn-sign-in">Giriş Yap →</button>
      <button class="btn-ghost" onclick="goTo('screen-invite')" id="btn-go-register">Hesabın yok mu? Kayıt ol</button>
    </div>
  </div>

  <!-- SCREEN: SPLASH -->
  <div class="screen active" id="screen-splash">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons">
        <div class="status-icon signal"></div>
        <div class="status-icon battery"></div>
      </div>
    </div>
    <div class="splash-top">
      <div class="splash-logo">✈️</div>
      <div class="splash-title font-display">CrewGuide</div>
      <div class="splash-tagline" id="splash-tagline">Havacılık çalışanlarının<br>dünya rehberi</div>
      <div class="lang-dropdown-wrapper">
        <button class="lang-dropdown-btn" id="lang-dropdown-btn" onclick="toggleLangDropdown()">
          <span id="lang-btn-flag">🇹🇷</span>
          <span id="lang-btn-name">Türkçe</span>
          <span class="arrow">▼</span>
        </button>
        <div class="lang-dropdown-menu" id="lang-dropdown-menu">
          <button class="lang-option active" data-lang="tr" onclick="selectLang('tr')">
            <span class="lang-flag">🇹🇷</span><span class="lang-name">Türkçe</span>
          </button>
          <button class="lang-option" data-lang="en" onclick="selectLang('en')">
            <span class="lang-flag">🇬🇧</span><span class="lang-name">English</span>
          </button>
          <button class="lang-option" data-lang="de" onclick="selectLang('de')">
            <span class="lang-flag">🇩🇪</span><span class="lang-name">Deutsch</span>
          </button>
          <button class="lang-option" data-lang="fr" onclick="selectLang('fr')">
            <span class="lang-flag">🇫🇷</span><span class="lang-name">Français</span>
          </button>
          <button class="lang-option" data-lang="es" onclick="selectLang('es')">
            <span class="lang-flag">🇪🇸</span><span class="lang-name">Español</span>
          </button>
          <button class="lang-option" data-lang="ar" onclick="selectLang('ar')">
            <span class="lang-flag">🇦🇪</span><span class="lang-name">العربية</span>
          </button>
          <button class="lang-option" data-lang="ja" onclick="selectLang('ja')">
            <span class="lang-flag">🇯🇵</span><span class="lang-name">日本語</span>
          </button>
          <button class="lang-option" data-lang="ko" onclick="selectLang('ko')">
            <span class="lang-flag">🇰🇷</span><span class="lang-name">한국어</span>
          </button>
          <button class="lang-option" data-lang="zh" onclick="selectLang('zh')">
            <span class="lang-flag">🇨🇳</span><span class="lang-name">中文</span>
          </button>
        </div>
      </div>
    </div>
    <div class="splash-bottom">
      <button class="btn-primary" onclick="goTo('screen-invite')" id="btn-have-code">Davet Kodum Var →</button>
      <button class="btn-outline" onclick="goTo('screen-login')" id="btn-login">Giriş Yap</button>
      <div class="splash-note" id="splash-note">Sadece davet ile üye olunabilir.<br>Tüm kişisel bilgiler gizli tutulur.</div>
    </div>
  </div>

  <!-- SCREEN: INVITE -->
  <div class="screen" id="screen-invite">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header">
      <div class="nav-back" onclick="goTo('screen-splash')" id="back-splash"></div>
      <div class="header-title font-display" id="invite-title">Davet Kodu</div>
      <div class="header-sub" id="invite-sub">Adım 1/3</div>
      <div class="step-indicator">
        <div class="step-dot active"></div>
        <div class="step-dot"></div>
        <div class="step-dot"></div>
      </div>
    </div>
    <div class="screen-body">
      <div class="invite-visual">
        <div class="invite-icon-big">🔐</div>
        <div class="invite-desc" id="invite-desc">CrewGuide yalnızca davet ile kullanılabilir. Bir ekip arkadaşından kod al.</div>
      </div>
      <div class="code-entry">
        <div class="field-label" id="invite-code-label">DAVET KODU</div>
        <input
          class="field-input"
          type="text"
          id="invite-code-input"
          placeholder="CRW-XXXXX"
          maxlength="10"
          autocomplete="off"
          autocapitalize="characters"
          style="text-align:center;font-family:'Syne',sans-serif;font-size:22px;font-weight:700;letter-spacing:4px;"
        >
        <div class="code-hint" id="invite-hint">7 haneli davet kodu · Büyük/küçük harf duyarsız</div>
      </div>
      <button class="btn-navy" onclick="verifyInviteCode()" id="btn-continue">Devam Et →</button>
      <button class="btn-ghost" id="btn-no-code" onclick="showToast(lang==='tr'?'Bir ekip arkadaşından davet kodu iste.':'Ask a colleague for an invite code.')">Kodum yok, nasıl alabilirim?</button>
    </div>
  </div>

  <!-- SCREEN: PROFILE SETUP -->
  <div class="screen" id="screen-profile">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header">
      <div class="nav-back" onclick="goTo('screen-invite')" id="back-invite"></div>
      <div class="header-title font-display" id="profile-setup-title">Profil Oluştur</div>
      <div class="header-sub" id="profile-setup-sub">Adım 2/3</div>
      <div class="step-indicator">
        <div class="step-dot"></div>
        <div class="step-dot active"></div>
        <div class="step-dot"></div>
      </div>
    </div>
    <div class="screen-body">
      <div class="avatar-picker">
        <div class="avatar-circle">✈️</div>
        <div class="avatar-hint" id="avatar-hint">Fotoğraf ekle (opsiyonel)</div>
      </div>
      <div class="field-group">
        <div class="field-label" id="label-displayname">GÖRÜNEN AD — HERKESE AÇIK</div>
        <input class="field-input" type="text" placeholder="CaptainSeoul" id="input-displayname">
      </div>
      <div class="field-group">
        <div class="field-label" id="label-email">E-POSTA — SADECE GİRİŞ İÇİN</div>
        <input class="field-input" type="email" placeholder="email@gmail.com" id="input-email">
      </div>
      <div class="field-group">
        <div class="field-label" id="label-password">ŞİFRE</div>
        <input class="field-input" type="password" placeholder="••••••••" id="input-password">
      </div>
      <div class="privacy-box">
        <div class="privacy-box-icon">🔒</div>
        <div class="privacy-box-text" id="privacy-text">E-posta ve şifren hiçbir zaman başkalarıyla paylaşılmaz. Diğer kullanıcılar yalnızca görünen adını görebilir.</div>
      </div>
      <button class="btn-navy" onclick="createAccount()" id="btn-create-account">Hesap Oluştur →</button>
    </div>
  </div>

  <!-- SCREEN: WELCOME -->
  <div class="screen" id="screen-welcome" style="background:var(--navy);">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="welcome-body">
      <div class="welcome-emoji">🎉</div>
      <div class="welcome-title font-display" id="welcome-title">Hoş geldin!</div>
      <div class="welcome-sub" id="welcome-sub">Artık dünya genelinde ekip arkadaşlarının tavsiyelerine ulaşabilirsin.</div>
      <div class="invite-code-display">
        <div class="invite-code-label" id="your-code-label">SENİN DAVET KODUN</div>
        <div class="invite-code-value">CRW-X7K</div>
        <div class="invite-code-quota" id="invite-quota-text">3 arkadaşını davet edebilirsin</div>
      </div>
      <button class="btn-primary" onclick="goTo('screen-home')" id="btn-explore">Keşfetmeye Başla →</button>
    </div>
  </div>

  <!-- SCREEN: HOME -->
  <div class="screen" id="screen-home">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="home-header">
      <div class="home-top">
        <div class="home-logo font-display">CrewGuide</div>
        <div class="home-avatar" onclick="goTo('screen-profile-view')">✈️</div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
        <div class="location-pill" onclick="detectLocation()" id="location-pill" style="margin-bottom:0;flex:1;">
          <div class="location-dot" id="location-dot"></div>
          <span id="location-text">📍 Seoul, Güney Kore</span>
        </div>
        <div id="currency-badge" onclick="showCurrencyInfo()" style="
          display:inline-flex;align-items:center;gap:5px;
          background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.35);
          border-radius:20px;padding:5px 11px;cursor:pointer;flex-shrink:0;
        ">
          <span id="currency-symbol" style="font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--gold);">₩</span>
          <span id="currency-code" style="font-size:10px;color:rgba(255,255,255,0.7);font-weight:500;">KRW</span>
        </div>
      </div>
      <div class="search-bar" style="padding:0;">
        <input
          type="text"
          id="search-input"
          autocomplete="off"
          placeholder=""
          style="flex:1;background:transparent;border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:13px;color:rgba(255,255,255,0.85);padding:10px 0 10px 14px;"
          oninput="onSearch(this.value)"
        >
        <div class="search-icon" style="padding:0 12px 0 0;">🔍</div>
      </div>
      <div class="cat-tabs">
        <button class="cat-tab active" onclick="filterCat('all', this)" id="tab-all">Tümü</button>
        <button class="cat-tab" onclick="filterCat('food', this)" id="tab-food">🍜 Yemek</button>
        <button class="cat-tab" onclick="filterCat('shopping', this)" id="tab-shopping">🛍 Alışveriş</button>
        <button class="cat-tab" onclick="filterCat('sightseeing', this)" id="tab-sight">🗺 Gezi</button>
      </div>
    </div>

    <!-- Filtre bar -->
    <div class="filter-bar" id="filter-bar">
      <button class="filter-chip" id="chip-price" onclick="openFilterPanel('price')">💰 <span id="chip-price-label">Fiyat</span></button>
      <button class="filter-chip" id="chip-rating" onclick="openFilterPanel('rating')">⭐ <span id="chip-rating-label">Puan</span></button>
      <button class="filter-chip" id="chip-sort" onclick="openFilterPanel('sort')">↕ <span id="chip-sort-label">Sırala</span></button>
      <button class="filter-chip" id="chip-reset" onclick="resetFilters()" style="display:none;">✕ Temizle</button>
    </div>

    <!-- Sonuç sayısı -->
    <!-- +18 filtre satırı -->
    <div class="adult-filter-row" id="adult-filter-row">
      <span class="adult-filter-label" id="adult-filter-label">🔞 +18 içerikleri göster</span>
      <div class="toggle off" id="toggle-show-adult" onclick="toggleShowAdult(this)" style="transform:scale(0.85);">
        <div class="toggle-knob"></div>
      </div>
    </div>

    <div class="results-bar" id="results-bar">
      <span class="results-count" id="results-count"></span>
    </div>

    <!-- Filtre overlay -->
    <div class="filter-overlay" id="filter-overlay" onclick="closeFilterPanel()"></div>

    <!-- Filtre panel -->
    <div class="filter-panel" id="filter-panel">
      <div class="filter-panel-handle"></div>
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div class="filter-panel-title" id="filter-panel-title">Filtrele</div>
        <button onclick="closeFilterPanel()" style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--text-muted);">✕</button>
      </div>

      <!-- Fiyat filtresi -->
      <div id="filter-price-section">
        <div class="filter-section-label" id="filter-price-label">Fiyat Aralığı</div>
        <div class="filter-option-grid" id="filter-price-opts">
          <button class="filter-opt-btn" data-val="$" onclick="toggleFilterOpt(this,'price')">$ Uygun</button>
          <button class="filter-opt-btn" data-val="$$" onclick="toggleFilterOpt(this,'price')">$$ Orta</button>
          <button class="filter-opt-btn" data-val="$$$" onclick="toggleFilterOpt(this,'price')">$$$ Pahalı</button>
        </div>
      </div>

      <!-- Puan filtresi -->
      <div id="filter-rating-section">
        <div class="filter-section-label" id="filter-rating-label">Minimum Puan</div>
        <div class="filter-rating-row" id="filter-rating-opts">
          <button class="filter-rating-btn" data-val="3" onclick="selectRatingFilter(this)">3+ ⭐</button>
          <button class="filter-rating-btn" data-val="4" onclick="selectRatingFilter(this)">4+ ⭐</button>
          <button class="filter-rating-btn" data-val="4.5" onclick="selectRatingFilter(this)">4.5+ ⭐</button>
        </div>
      </div>

      <!-- Sıralama -->
      <div id="filter-sort-section">
        <div class="filter-section-label" id="filter-sort-label">Sıralama</div>
        <div class="filter-option-grid" id="filter-sort-opts">
          <button class="filter-opt-btn selected" data-val="default" onclick="toggleFilterOpt(this,'sort')">Varsayılan</button>
          <button class="filter-opt-btn" data-val="rating" onclick="toggleFilterOpt(this,'sort')">En Yüksek Puan</button>
          <button class="filter-opt-btn" data-val="likes" onclick="toggleFilterOpt(this,'sort')">En Çok Beğenilen</button>
          <button class="filter-opt-btn" data-val="newest" onclick="toggleFilterOpt(this,'sort')">En Yeni</button>
        </div>
      </div>

      <div class="filter-actions">
        <button class="filter-clear-btn" onclick="resetFilters();closeFilterPanel();" id="filter-clear-btn">Temizle</button>
        <button class="filter-apply-btn" onclick="applyFilters();closeFilterPanel();" id="filter-apply-btn">Uygula</button>
      </div>
    </div>

    <div class="home-content" id="home-content">
      <!-- Cards injected by JS -->
    </div>
    <div class="bottom-nav">
      <div class="bnav-item active"><div class="bnav-icon">🏠</div><div class="bnav-label" id="bnav-home">Keşfet</div></div>
      <div class="bnav-item" onclick="goTo('screen-saved')"><div class="bnav-icon">🔖</div><div class="bnav-label" id="bnav-saved">Kayıtlı</div></div>
      <div class="bnav-item" onclick="goTo('screen-add')"><div class="bnav-add">＋</div></div>
      <div class="bnav-item" onclick="goTo('screen-profile-view')"><div class="bnav-icon">👤</div><div class="bnav-label" id="bnav-profile">Profil</div></div>
    </div>
  </div>

  <!-- SCREEN: DETAIL -->
  <div class="screen" id="screen-detail">
    <div class="detail-hero food" id="detail-hero">
      <div class="detail-back" onclick="goTo('screen-home')">←</div>
      <div class="detail-save" id="detail-save-btn" onclick="toggleSave()">🔖</div>
      <span id="detail-emoji" style="font-size:64px;">🥩</span>
    </div>
    <div class="detail-body">
      <div class="detail-name font-display" id="detail-name">Mukbang BBQ</div>
      <div class="detail-addr">📍 <span id="detail-addr">Mapo-gu, Seoul</span></div>
      <div class="detail-badges">
        <span class="badge badge-cat" id="detail-cat-badge">Yemek</span>
        <span class="badge badge-sub" id="detail-sub-badge">Restoran</span>
        <span class="badge badge-price" id="detail-price-badge">$$ Orta</span>
      </div>
      <div id="detail-gallery" class="detail-gallery" style="display:none;"></div>
      <div id="detail-rating-bar" class="star-rating-bar">
        <div class="star-rating-title" id="rating-title">Puan</div>
        <div class="star-rating-summary">
          <div class="star-big-num" id="rating-avg">4.6</div>
          <div class="star-big-right">
            <div class="stars-display" id="rating-stars-display"></div>
            <div class="star-count-text" id="rating-count">34 değerlendirme</div>
          </div>
          <div class="star-bars" id="rating-bars" style="flex:1;"></div>
        </div>
        <div class="star-input-row">
          <div class="star-input-label" id="rate-prompt">Puanla:</div>
          <div class="star-input" id="star-input">
            <span onclick="setUserRating(1)" onmouseover="hoverStars(1)" onmouseout="unhoverStars()">★</span>
            <span onclick="setUserRating(2)" onmouseover="hoverStars(2)" onmouseout="unhoverStars()">★</span>
            <span onclick="setUserRating(3)" onmouseover="hoverStars(3)" onmouseout="unhoverStars()">★</span>
            <span onclick="setUserRating(4)" onmouseover="hoverStars(4)" onmouseout="unhoverStars()">★</span>
            <span onclick="setUserRating(5)" onmouseover="hoverStars(5)" onmouseout="unhoverStars()">★</span>
          </div>
          <button class="star-submit-btn" onclick="submitRating()" id="btn-rate">Oyla</button>
        </div>
      </div>
      <div class="map-placeholder" id="map-placeholder-btn" onclick="openMapModal()">🗺 <span id="map-text">Haritada Göster</span></div>
      <div class="detail-section">
        <div class="detail-section-title" id="about-title">Hakkında</div>
        <div class="detail-desc" id="detail-desc">Sınırsız Kore barbekü, 90 dk. Akşam yoğun olur, öğlen git. Ödeme nakit tercih ediyorlar.</div>
      </div>
      <div class="detail-section">
        <div class="detail-section-title" id="reviews-title">Yorumlar</div>
        <div id="comments-list" class="comments-list">
          <div class="comment-loading" id="comments-loading">⏳ Yorumlar yükleniyor...</div>
        </div>

        <!-- Yorum yaz -->
        <div class="comment-input-box" id="comment-input-box">
          <div class="comment-input-header" id="comment-input-title">Yorum Yaz</div>
          <div class="comment-name-row">
            <input class="comment-name-input" type="text" id="comment-username"
              placeholder="Görünen adın (örn. CaptainSeoul)" maxlength="30"
              autocomplete="off">
            <div class="comment-star-pick" id="comment-star-pick">
              <span onclick="setCommentStar(1)" onmouseover="hoverCommentStar(1)" onmouseout="unhoverCommentStar()">★</span>
              <span onclick="setCommentStar(2)" onmouseover="hoverCommentStar(2)" onmouseout="unhoverCommentStar()">★</span>
              <span onclick="setCommentStar(3)" onmouseover="hoverCommentStar(3)" onmouseout="unhoverCommentStar()">★</span>
              <span onclick="setCommentStar(4)" onmouseover="hoverCommentStar(4)" onmouseout="unhoverCommentStar()">★</span>
              <span onclick="setCommentStar(5)" onmouseover="hoverCommentStar(5)" onmouseout="unhoverCommentStar()">★</span>
            </div>
          </div>
          <textarea class="comment-textarea" id="comment-text"
            placeholder="Deneyimini paylaş..." maxlength="300"></textarea>
          <button class="comment-submit-btn" id="comment-submit-btn" onclick="submitComment()">
            💬 <span id="comment-submit-label">Yorum Gönder</span>
          </button>
        </div>
      </div>
      <div class="detail-actions">
        <button class="action-btn" id="btn-like" onclick="toggleLike()">♥ <span id="like-label">Beğen</span></button>
        <button class="action-btn" id="btn-save-detail" onclick="toggleSave()">🔖 <span id="save-label">Kaydet</span></button>
        <button class="action-btn primary" id="btn-comment" onclick="scrollToCommentInput()">💬 <span id="comment-label">Yorum</span></button>
      </div>
      <!-- Admin silme butonu — sadece admin görebilir -->
      <div id="admin-actions" style="display:none;margin-top:4px;">
        <button onclick="adminDeletePlace()" style="
          width:100%;padding:11px;border-radius:var(--radius-sm);
          background:#fef2f2;border:1.5px solid #fca5a5;
          color:#ef4444;font-size:13px;font-weight:600;
          font-family:'Syne',sans-serif;cursor:pointer;">
          🗑 Yeri Kaldır (Admin)
        </button>
      </div>
    </div>
  </div>

  <!-- SCREEN: ADD PLACE -->
  <div class="screen" id="screen-add">
    <div class="status-bar">
      <span class="status-time">09:41</span>
      <div class="status-icons"><div class="status-icon signal"></div><div class="status-icon battery"></div></div>
    </div>
    <div class="navy-header">
