      <div id="sub-cat-section">
        <div class="field-label" id="label-sub-cat" style="margin-bottom:8px;">ALT KATEGORİ</div>
        <div class="sub-cat-wrap" id="sub-cats"></div>
      </div>
      <div class="field-group">
        <div class="field-label" id="label-place-name">YER ADI</div>
        <input class="field-input" type="text" id="input-place-name" placeholder="Mukbang BBQ">
      </div>
      <div class="field-group">
        <div class="field-label" id="label-place-addr">ADRES / KONUM</div>
        <div style="display:flex;gap:8px;align-items:center;">
          <input class="field-input" type="text" id="input-place-addr" placeholder="Mapo-gu, Seoul" style="flex:1;margin:0;">
          <button onclick="fillCurrentLocation()" id="btn-gps-location" title="Mevcut konumu kullan" style="
            flex-shrink:0; width:44px; height:44px; border-radius:var(--radius-sm);
            background:var(--navy); color:#fff; border:none; cursor:pointer;
            font-size:18px; display:flex; align-items:center; justify-content:center;
            transition:opacity 0.2s;">📍</button>
        </div>
        <div id="gps-status" style="font-size:11px;color:var(--text-muted);margin-top:4px;display:none;"></div>
      </div>
      <div>
        <div class="field-label" id="label-price" style="margin-bottom:8px;">FİYAT ARALIĞI</div>
        <div class="price-grid">
          <div class="price-opt selected" onclick="selectPrice(this)">
            <span class="price-sym">$</span>
            <span class="price-name" id="price-cheap">Uygun</span>
          </div>
          <div class="price-opt" onclick="selectPrice(this)">
            <span class="price-sym">$$</span>
            <span class="price-name" id="price-mid">Orta</span>
          </div>
          <div class="price-opt" onclick="selectPrice(this)">
            <span class="price-sym">$$$</span>
            <span class="price-name" id="price-high">Pahalı</span>
          </div>
        </div>
      </div>
      <div class="field-group">
        <div class="field-label" id="label-desc">AÇIKLAMA & NOTLAR</div>
        <textarea class="field-textarea" id="input-desc" placeholder="Sınırsız et, 90 dk, akşam kalabalık..."></textarea>
      </div>
      <div>
        <div class="field-label" id="label-photos" style="margin-bottom:8px;">FOTOĞRAFLAR</div>
        <input type="file" id="photo-file-input" accept="image/*" multiple style="display:none" onchange="handlePhotoSelect(this)">
        <div class="photo-upload-area" id="photo-upload-area" onclick="document.getElementById('photo-file-input').click()">
          <div class="photo-upload-icon">📷</div>
          <div class="photo-upload-text" id="photo-text">Fotoğraf Ekle</div>
          <div class="photo-upload-opt" id="photo-opt">Opsiyonel · En fazla 5 fotoğraf · 5 MB/fotoğraf</div>
        </div>
        <div class="photo-preview-grid" id="photo-preview-grid"></div>
        <div class="photo-progress" id="photo-progress">
          <div class="photo-progress-fill" id="photo-progress-fill"></div>
        </div>
      </div>
      <!-- +18 Toggle -->
      <div class="adult-toggle-row">
        <div class="adult-toggle-left">
          <div class="adult-toggle-icon">🔞</div>
          <div>
            <div class="adult-toggle-label" id="adult-toggle-label">Yetişkinlere Yönelik</div>
            <div class="adult-toggle-sub" id="adult-toggle-sub">Bar, gece kulübü, casino vb.</div>
          </div>
        </div>
        <div class="toggle off" id="toggle-adult" onclick="toggleAdultContent(this)">
          <div class="toggle-knob"></div>
        </div>
      </div>

      <button class="btn-navy" onclick="submitPlace()" id="btn-submit">Paylaş →</button>
      <div style="height:20px;"></div>
    </div>
  </div>

