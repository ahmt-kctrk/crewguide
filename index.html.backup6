function setLang(l, btn) {
  lang = l;
  localStorage.setItem('crewguide_lang', l);
  document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.lang-setting-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.lang === l);
  });
  applyTranslations();
}

function setLangFromSettings(l) {
  lang = l;
  localStorage.setItem('crewguide_lang', l);

  // RTL desteği (Arapça)
  document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';

  // Splash butonları güncelle
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));

  // Ayarlar butonları güncelle
  document.querySelectorAll('.lang-setting-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.lang === l);
  });

  applyTranslations();
  showToast(translations[l] ? '✓ ' + {
    tr:'Türkçe', en:'English', de:'Deutsch', fr:'Français',
    es:'Español', ar:'العربية', ja:'日本語', ko:'한국어', zh:'中文'
  }[l] : '');
}


function applyTranslations() {
  const t = translations[lang];
  for (const [id, val] of Object.entries(t)) {
    const el = document.getElementById(id);
    if (el) el.innerHTML = val;
  }
  renderCards();
  renderSubCats();
  updateFilterChips();
}

function goTo(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById(id).scrollTop = 0;
  if (id === 'screen-home' && !locationDetected) {
    locationDetected = true;
    useCurrentLocation();
  }
  // Home'a ilk gelişte bildirim izni sor
  if (id === 'screen-home') {
    setTimeout(() => askNotificationPermission(), 500);
  }
  // Ayarlar ekranı açılınca mevcut durumu göster
  if (id === 'screen-settings') {
    checkNotifStatus();
  }
  // Her ekran değişiminde çevirileri uygula
  applyTranslations();
}
let locationDetected = false;

function renderCards() {
  const container = document.getElementById('home-content');
  let filtered = currentCat === 'all' ? [...places] : places.filter(p => p.cat === currentCat);

  // Metin araması
  const q = (document.getElementById('search-input') ? document.getElementById('search-input').value : '').trim().toLowerCase();
  if (q) {
    filtered = filtered.filter(p =>
      p.name.toLowerCase().includes(q) ||
      p.addr.toLowerCase().includes(q) ||
      p.subcat.toLowerCase().includes(q) ||
      (p.desc[lang] && p.desc[lang].toLowerCase().includes(q))
    );
  }

  // +18 filtresi — default gizli
  if (!showAdultContent) {
    filtered = filtered.filter(p => !p.isAdult);
  }

  // Fiyat filtresi
  if (activeFilters && activeFilters.price && activeFilters.price.length > 0) {
    filtered = filtered.filter(p => activeFilters.price.includes(p.price));
  }

  // Puan filtresi
  if (activeFilters && activeFilters.rating) {
    filtered = filtered.filter(p => p.rating >= activeFilters.rating);
  }

  // Sıralama
  if (activeFilters && activeFilters.sort) {
    if (activeFilters.sort === 'rating') {
      filtered.sort((a, b) => (b.rating || 0) - (a.rating || 0));
    } else if (activeFilters.sort === 'likes') {
      filtered.sort((a, b) => (b.likes || 0) - (a.likes || 0));
    } else if (activeFilters.sort === 'newest') {
      filtered.reverse();
    }
  }

  // Sonuç sayısı güncelle
  const countEl = document.getElementById('results-count');
  if (countEl) {
    countEl.textContent = filtered.length > 0
      ? `${filtered.length} ${lang==='tr'?'yer bulundu':'places found'}`
      : '';
  }

  if (filtered.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:40px 20px;color:var(--text-muted);"><div style="font-size:36px;margin-bottom:10px;">🔍</div><div style="font-size:14px;">' + (lang==='tr'?'Sonuç bulunamadı.':'No results found.') + '</div></div>';
    return;
  }
  container.innerHTML = filtered.map(p => `
    <div class="place-card" onclick="openDetail('${p.id}')">
      <div class="place-card-img ${p.cat}">
        <div class="card-badge">${p.subcat}</div>
        ${p.isAdult ? '<div class="card-adult-badge">🔞 +18</div>' : ''}
        <span>${p.emoji}</span>
      </div>
      <div class="place-card-body">
        <div class="place-card-name">${p.name}</div>
        <div class="place-card-meta">${p.addr}</div>
        <div class="place-card-row">
          <span class="price-tag" title="${getPriceRangeLocal(p.price, currentCurrency)} ${currentCurrency.code}">
            ${p.price} · <span style="color:var(--gold);font-weight:600;">${getPriceRangeLocal(p.price, currentCurrency)}</span>
          </span>
          <span class="likes-tag">
            ${p.rating > 0 ? `<span class="card-stars">${'★'.repeat(Math.round(p.rating))}${'☆'.repeat(5-Math.round(p.rating))}</span><span class="card-rating-num">${p.rating.toFixed(1)}</span>` : `<span class="heart">♥</span> ${p.likes}`}
          </span>
        </div>
      </div>
    </div>
  `).join('');
}

function filterCat(cat, btn) {
  currentCat = cat;
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  renderCards();
}

let currentDetailId = null;
let pendingRating = 0;

function openDetail(id) {
  const p = places.find(x => x.id === id);
  if (!p) return;
  currentDetailId = id;
  pendingRating = 0;
  document.getElementById('detail-hero').className = `detail-hero ${p.cat}`;
  document.getElementById('detail-emoji').textContent = p.emoji;
  document.getElementById('detail-name').textContent = p.name;
  document.getElementById('detail-addr').textContent = p.addr;
  document.getElementById('detail-cat-badge').textContent = lang==='tr' ? (p.cat==='food'?'Yemek':p.cat==='shopping'?'Alışveriş':'Gezi') : (p.cat==='food'?'Food':p.cat==='shopping'?'Shopping':'Sightseeing');
  document.getElementById('detail-sub-badge').textContent = p.subcat;
  const localAmt = getPriceRangeLocal(p.price, currentCurrency);
  document.getElementById('detail-price-badge').innerHTML =
    `${p.price} ${p.priceName[lang]} <span style="color:#92400e;font-weight:700;">· ${localAmt} ${currentCurrency.code}</span>`;
  document.getElementById('detail-desc').textContent = p.desc[lang];
  renderRatingBar(p);
  // Yorum input başlığını ve placeholder'ı güncelle
  commentPlaceId = p.id;
  commentStar = 0;
  updateCommentStars(0, true);
  const titleEl = document.getElementById('comment-input-title');
  const taEl = document.getElementById('comment-text');
  const btnEl = document.getElementById('comment-submit-label');
  if (titleEl) titleEl.textContent = lang==='tr' ? 'Yorum Yaz' : 'Write a Review';
  if (taEl) taEl.placeholder = lang==='tr' ? 'Deneyimini paylaş...' : 'Share your experience...';
  if (btnEl) btnEl.textContent = lang==='tr' ? 'Yorum Gönder' : 'Send Comment';
  // Giriş yapılmışsa ismi kilitle
  const usernameInput = document.getElementById('comment-username');
  if (usernameInput && currentProfile) {
    usernameInput.value = currentProfile.username;
    usernameInput.readOnly = true;
    usernameInput.style.background = 'var(--cream-dark)';
    usernameInput.style.color = 'var(--text-secondary)';
  } else if (usernameInput) {
    usernameInput.readOnly = false;
    usernameInput.style.background = '';
    usernameInput.style.color = '';
  }
  loadComments(p.id);
  loadPlacePhotos(p.id);
  // Admin butonunu göster/gizle
  const adminActions = document.getElementById('admin-actions');
  if (adminActions) adminActions.style.display = isAdmin() ? 'block' : 'none';
  goTo('screen-detail');
}

function renderRatingBar(p) {
  // Ortalama & yıldız gösterimi
  const avg = p.rating || 0;
  const count = p.ratingCount || 0;
  document.getElementById('rating-avg').textContent = avg > 0 ? avg.toFixed(1) : '—';
  const ratingTitles = {tr:'Puan',en:'Rating',de:'Bewertung',fr:'Note',es:'Calificación',ar:'التقييم',ja:'評価',ko:'평점',zh:'评分'};
  const ratePrompts = {tr:'Puanla:',en:'Rate:',de:'Bewerten:',fr:'Noter:',es:'Calificar:',ar:'قيّم:',ja:'評価する:',ko:'평가:',zh:'评分:'};
  const _l = lang || 'tr';
  document.getElementById('rating-title').textContent = ratingTitles[_l] || ratingTitles.en;
  document.getElementById('rate-prompt').textContent = ratePrompts[_l] || ratePrompts.en;
  document.getElementById('btn-rate').textContent = lang === 'tr' ? 'Oyla' : 'Rate';
  document.getElementById('rating-count').textContent = count > 0
    ? `${count} ${lang === 'tr' ? 'değerlendirme' : 'ratings'}`
    : (lang === 'tr' ? 'Henüz puan yok' : 'No ratings yet');

  // Yıldız display
  const starsEl = document.getElementById('rating-stars-display');
  starsEl.innerHTML = '';
  for (let i = 1; i <= 5; i++) {
    const s = document.createElement('span');
    s.textContent = i <= Math.round(avg) ? '★' : '☆';
    s.style.color = i <= Math.round(avg) ? '#f59e0b' : '#d1d5db';
    s.style.fontSize = '16px';
    starsEl.appendChild(s);
  }

  // Bar chart
  const barsEl = document.getElementById('rating-bars');
  barsEl.innerHTML = '';
  const distrib = p.ratings || {5:0,4:0,3:0,2:0,1:0};
  const maxVal = Math.max(...Object.values(distrib), 1);
  [5,4,3,2,1].forEach(star => {
    const val = distrib[star] || 0;
    const pct = Math.round((val / (count || 1)) * 100);
    barsEl.innerHTML += `
      <div class="star-bar-row">
        <div class="star-bar-label">${star}</div>
        <div class="star-bar-track"><div class="star-bar-fill" style="width:${pct}%"></div></div>
        <div class="star-bar-num">${val}</div>
      </div>`;
  });

  // Kullanıcı daha önce oy verdiyse göster
  if (p.userRating > 0) {
    updateStarInput(p.userRating, true);
    pendingRating = p.userRating;
  } else {
    updateStarInput(0, false);
  }
}

function hoverStars(n) {
  const stars = document.querySelectorAll('#star-input span');
  stars.forEach((s, i) => {
    s.style.filter = i < n ? 'none' : 'grayscale(1) opacity(0.4)';
    s.style.transform = i < n ? 'scale(1.15)' : 'scale(1)';
  });
}

function unhoverStars() {
  if (pendingRating > 0) {
    updateStarInput(pendingRating, false);
  } else {
    const stars = document.querySelectorAll('#star-input span');
    stars.forEach(s => {
      s.style.filter = 'grayscale(1) opacity(0.4)';
      s.style.transform = 'scale(1)';
    });
  }
}

function setUserRating(n) {
  pendingRating = n;
  updateStarInput(n, false);
}

function updateStarInput(n, submitted) {
  const stars = document.querySelectorAll('#star-input span');
  stars.forEach((s, i) => {
    s.style.filter = i < n ? 'none' : 'grayscale(1) opacity(0.4)';
    s.style.transform = 'scale(1)';
    s.style.color = i < n ? '#f59e0b' : '';
  });
  if (submitted) {
    document.getElementById('btn-rate').textContent = lang === 'tr' ? '✓ Oylandı' : '✓ Rated';
    document.getElementById('btn-rate').style.background = '#10b981';
  }
}

function submitRating() {
  if (pendingRating === 0) {
    showToast(lang === 'tr' ? 'Önce bir yıldız seç!' : 'Select a star first!');
    return;
  }
  const p = places.find(x => x.id === currentDetailId);
  if (!p) return;

  const prev = p.userRating || 0;

  // Önceki oy varsa çıkar, yenisini ekle
  if (prev > 0 && p.ratings[prev] > 0) {
    p.ratings[prev]--;
    p.ratingCount--;
  }
  p.ratings[pendingRating] = (p.ratings[pendingRating] || 0) + 1;
  p.ratingCount++;
  p.userRating = pendingRating;

  // Ortalama yeniden hesapla
  let total = 0, count = 0;
  [1,2,3,4,5].forEach(s => { total += s * (p.ratings[s] || 0); count += (p.ratings[s] || 0); });
  p.rating = count > 0 ? Math.round((total / count) * 10) / 10 : 0;

  renderRatingBar(p);
  updateStarInput(pendingRating, true);
  renderCards();
  showToast(lang === 'tr'
    ? `${pendingRating} yıldız verdin! ★`
    : `You rated ${pendingRating} stars! ★`);
}

function toggleLike() {
  liked = !liked;
  const btn = document.getElementById('btn-like');
  btn.style.color = liked ? '#ef4444' : '';
  btn.style.borderColor = liked ? '#fca5a5' : '';
  document.getElementById('like-label').textContent = liked ? (lang==='tr'?'Beğenildi':'Liked') : (lang==='tr'?'Beğen':'Like');
}

function toggleSave() {
  saved = !saved;
  const btn = document.getElementById('detail-save-btn');
  const btn2 = document.getElementById('btn-save-detail');
  btn.textContent = saved ? '🔖' : '🔖';
  btn.style.background = saved ? '#fef3c7' : 'rgba(255,255,255,0.9)';
  document.getElementById('save-label').textContent = saved ? (lang==='tr'?'Kaydedildi':'Saved') : (lang==='tr'?'Kaydet':'Save');
  showToast(saved ? (lang==='tr'?'Kayıtlılara eklendi!':'Added to saved!') : (lang==='tr'?'Kaydedilenlerden çıkarıldı.':'Removed from saved.'));
}

function selectMainCat(cat, el) {
  selectedMainCat = cat;
  document.querySelectorAll('.main-cat-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  renderSubCats();
}

function renderSubCats() {
  const wrap = document.getElementById('sub-cats');
  const cats = subcats[selectedMainCat];
  wrap.innerHTML = cats.map((c,i) => `<div class="sub-cat-btn${i===0?' selected':''}" onclick="this.parentNode.querySelectorAll('.sub-cat-btn').forEach(b=>b.classList.remove('selected'));this.classList.add('selected')">${c[lang]}</div>`).join('');
}

function selectPrice(el) {
  document.querySelectorAll('.price-opt').forEach(p => p.classList.remove('selected'));
  el.classList.add('selected');
}

// Admin email — bunu kendi emailinle değiştir
const ADMIN_EMAIL = 'ahmtkctrk@gmail.com';

function isAdmin() {
  if (!currentUser) return false;
  if (currentUser.email === ADMIN_EMAIL) return true;
  if (currentProfile && currentProfile.role === 'admin') return true;
  return false;
}

let isAdultContent = false;
let showAdultContent = false;

function toggleAdultContent(el) {
  el.classList.toggle('on');
  el.classList.toggle('off');
  isAdultContent = el.classList.contains('on');
}

function toggleShowAdult(el) {
  el.classList.toggle('on');
  el.classList.toggle('off');
  showAdultContent = el.classList.contains('on');
  renderCards();
}

async function submitPlace() {
  const name = document.getElementById('input-place-name').value.trim();
  const addr = document.getElementById('input-place-addr').value.trim();
  const desc = document.getElementById('input-desc').value.trim();
  if (!name) { showToast(lang==='tr'?'Yer adı gerekli!':'Place name is required!'); return; }

  const selectedPrice = document.querySelector('.price-opt.selected .price-sym');
  const priceVal = selectedPrice ? selectedPrice.textContent : '$';
  const selectedSub = document.querySelector('.sub-cat-btn.selected');
  const subLabel = selectedSub ? selectedSub.textContent.trim() : '';

  const catEmojis = { food:'🍜', shopping:'🛍', sightseeing:'🗺' };
  const priceName = { '$':{tr:'Uygun',en:'Budget'}, '$$':{tr:'Orta',en:'Mid-range'}, '$$$':{tr:'Pahalı',en:'Expensive'} };

  const placeId = 'place_' + Date.now();
  const newPlace = {
    id: placeId,
    cat: selectedMainCat,
    subcat: subLabel,
    emoji: catEmojis[selectedMainCat],
    name: name,
    addr: addr || 'Seoul',
    price: priceVal,
    priceName: priceName[priceVal] || {tr:'Uygun',en:'Budget'},
    likes: 0,
    rating: 0, ratingCount: 0, ratings: {5:0,4:0,3:0,2:0,1:0},
    userRating: 0,
    isAdult: isAdultContent,
    userId: currentUser ? currentUser.id : null,
    desc: { tr: desc || '', en: desc || '' }
  };

  // Supabase'e kaydet
  try {
    await sbFetch('places', {
      method: 'POST',
      body: JSON.stringify({
        id: placeId,
        cat: selectedMainCat,
        subcat: subLabel,
        emoji: catEmojis[selectedMainCat],
        name, addr: addr || 'Seoul',
        price: priceVal,
        price_name_tr: (priceName[priceVal]||{}).tr || 'Uygun',
        price_name_en: (priceName[priceVal]||{}).en || 'Budget',
        desc_tr: desc || '', desc_en: desc || '',
        is_adult: isAdultContent,
        user_id: currentUser ? currentUser.id : null,
        is_hidden: false
      })
    });
  } catch(e) {
    console.warn('[submitPlace Supabase]', e);
    // DB hatası olsa bile yerel olarak ekle
  }

  places.unshift(newPlace);

  // Reset form
  document.getElementById('input-place-name').value = '';
  document.getElementById('input-place-addr').value = '';
  document.getElementById('input-desc').value = '';
  isAdultContent = false;
  const adultToggle = document.getElementById('toggle-adult');
  if (adultToggle) { adultToggle.className = 'toggle off'; }

  // Fotoğrafları yükle
  if (selectedPhotos.length > 0) {
    const btn = document.getElementById('btn-submit');
    if (btn) { btn.textContent = lang==='tr'?'Fotoğraflar yükleniyor...':'Uploading photos...'; btn.disabled = true; }
    uploadPhotos(newPlace.id).then(urls => {
      selectedPhotos = [];
      renderPhotoPreviews();
      if (btn) { btn.textContent = lang==='tr'?'Paylaş →':'Share →'; btn.disabled = false; }
      showToast(lang==='tr'?`Yer eklendi! 🎉`:`Place added! 🎉`);
      setTimeout(() => { goTo('screen-home'); renderCards(); }, 1000);
    });
  } else {
    showToast(lang==='tr'?'Yer başarıyla eklendi! 🎉':'Place added successfully! 🎉');
    setTimeout(() => { goTo('screen-home'); renderCards(); }, 1000);
  }
}

function createAccount() {
  const name = document.getElementById('input-displayname').value.trim();
  if (!name) { showToast(lang==='tr'?'Görünen ad gerekli!':'Display name is required!'); return; }
  goTo('screen-welcome');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

function openDownloadModal(city, flag) {
  const modal = document.getElementById('downloadModal');
  document.getElementById('downloadCityName').textContent = lang==='tr' ? `${city} İndir` : `Download ${city}`;
  document.getElementById('downloadCitySub').textContent = lang==='tr' ? `İnternetsiz kaldığında ${city} verilerine ulaşabilirsin.` : `Access ${city} data when you're offline.`;
  modal.classList.add('open');
}

function closeModal() {
  document.getElementById('downloadModal').classList.remove('open');
}

function toggleDownloadOption(el) {
  el.classList.toggle('on');
  el.classList.toggle('off');
  updateDownloadSize();
}

function updateDownloadSize() {
  const photosOn = document.getElementById('togglePhotos').classList.contains('on');
  const reviewsOn = document.getElementById('toggleReviews').classList.contains('on');
  let size = 2.1 + (reviewsOn ? 0.4 : 0) + (photosOn ? 16 : 0);
  document.getElementById('downloadSize').textContent = lang==='tr' ? `Toplam: ~${size.toFixed(1)} MB indirilecek` : `Total: ~${size.toFixed(1)} MB to download`;
}

function confirmDownload() {
  closeModal();
  showToast(lang==='tr'?'Paris indiriliyor... ✓':'Downloading Paris... ✓');
}

