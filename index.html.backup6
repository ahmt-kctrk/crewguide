// Fiyat seviyelerine karşılık gelen yaklaşık USD tutarları
const priceRangeUSD = { '$': 15, '$$': 40, '$$$': 90 };

let currentCurrency = currencyDB['Seoul']; // default

function getCurrencyForCity(cityName) {
  return currencyDB[cityName] || { symbol:'$', code:'USD', rate:1, name:{tr:'Amerikan Doları',en:'US Dollar'} };
}

function formatLocalPrice(usdPrice, currency) {
  const local = Math.round(usdPrice / currency.rate);
  // Binlik ayraç
  const formatted = local.toLocaleString('tr-TR');
  return `${currency.symbol}${formatted}`;
}

function getPriceRangeLocal(priceSymbol, currency) {
  const usd = priceRangeUSD[priceSymbol] || 15;
  return formatLocalPrice(usd, currency);
}

