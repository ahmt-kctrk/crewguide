    </div>
    <div class="add-body">
      <div>
        <div class="field-label" id="label-main-cat" style="margin-bottom:8px;">ANA KATEGORİ</div>
        <div class="main-cat-grid">
          <div class="main-cat-btn selected" onclick="selectMainCat('food', this)" id="cat-food">
            <span class="cat-emoji">🍜</span><span id="cat-food-label">Yemek</span>
          </div>
          <div class="main-cat-btn" onclick="selectMainCat('shopping', this)" id="cat-shopping">
            <span class="cat-emoji">🛍</span><span id="cat-shopping-label">Alışveriş</span>
          </div>
          <div class="main-cat-btn" onclick="selectMainCat('sightseeing', this)" id="cat-sight-btn">
